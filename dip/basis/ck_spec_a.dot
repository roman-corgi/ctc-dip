/* why separate channels and how are they tied back together
*
* The magic happens from clerks.dot. It contains the same clerks but with dawgie
* information tied to the nodes. Since they are all named the same among these
* channlized files and clerks.dot, the dip.basis.transmute distills then
* condenses them into a hidden monolithic concept if they have dawgie
* information associated with them. That is the real magic.
*/
digraph SpecAClerks
{
  graph [splines="ortho", rankdir=LR];

  alarm_cal [label="User requested update", shape="none"];
  alarm_cnf [label="User requested update", shape="none"];
  alarm_rec [label="User requested update", shape="none"];
  
  calib [label="Calibration", shape="circle"];
  config [label="Configuration", shape="circle"];
  recipe [label="Recipe", shape="circle"];

  l1_spec_a_odir [label="Output path for L1_spec_a 1..1", shape="ellipse",
                 valname="clerk.configuration.l1_spec_a.outdir",
                 valtype="dip.base.Configuration"];
  l1_spec_a_rec [label="recipe L1_spec_a 1..1", shape="cds",
                valname="clerk.recipe.l1_spec_a.recipe",
                valtype="dip.base.Recipe"];
  l1_spec_a_nllut [label="non linear calibration 1..1", shape="cds",
                     valname="clerk.calibration.l1_spec_a.nonlin",
                     valtype="dip.base.Calibration"];

  l2a_spec_a_odir [label="Output path for L2a_spec_a 1..1", shape="ellipse",
                 valname="clerk.configuration.l2a_spec_a.outdir",
                 valtype="dip.base.Configuration"];
  l2a_spec_a_rec [label="recipe L2a_spec_a 1..1", shape="cds",
                 valname="clerk.recipe.l2a_spec_a.recipe",
                 valtype="dip.base.Recipe"];
  l2a_spec_a_mbpm [label="spec_a bad pixel map 1..1", shape="cds",
                valname="clerk.calibration.l2a_spec_a.bad_pix_map",
                valtype="dip.base.Calibration"];
  l2a_spec_a_dnb  [label="spec_a dark (CIC/FPN/dark current) 1..1", shape="cds",
                  valname="clerk.calibration.l2a_spec_a.darks",
                  valtype="dip.base.Calibration"];
  l2a_spec_a_cti  [label="spec_a charge transfer efficiency 1..1", shape="cds",
                valname="clerk.calibration.l2a_spec_a.charge_xfer_eff",
                valtype="dip.base.Calibration"];
  l2a_spec_a_ff  [label="spec_a flat field 1..1", shape="cds",
                valname="clerk.calibration.l2a_spec_a.flat_field",
                valtype="dip.base.Calibration"];
  l2a_spec_a_kgain  [label="spec_a k-gain 1..1", shape="cds",
                valname="clerk.calibration.l2a_spec_a.k_gain",
                valtype="dip.base.Calibration"];
  l2a_spec_a_emg [label="spec_a EM gain 1..1", shape="cds",
                valname="clerk.calibration.l2a_spec_a.em_gain",
                valtype="dip.base.Calibration"];
  l2b_spec_a_odir [label="Output path for L2b_spec_a 1..1", shape="ellipse",
                 valname="clerk.configuration.l2b_spec_a.outdir",
                 valtype="dip.base.Configuration"];
  l2b_spec_a_rec [label="recipe L2b_spec_a 1..1", shape="cds",
                 valname="clerk.recipe.l2b_spec_a.recipe",
                 valtype="dip.base.Recipe"];
  l2b_spec_a_distm [label="spec_a distortion map 1..1", shape="cds",
                 valname="clerk.calibration.l2b_spec_a.distortion_map",
                 valtype="dip.base.Calibration"];
  l2b_spec_a_excicrf [label="spec_a EXCAM ICRF location 1..1", shape="cds",
                 valname="clerk.calibration.l2b_spec_a.excam_icrf_location",
                 valtype="dip.base.Calibration"];
  l2b_spec_a_excfovps [label="spec_a ECAM FOV pixel scale 1..1", shape="cds",
                 valname="clerk.calibration.l2b_spec_a.excam_fov_pixel_scale",
                 valtype="dip.base.Calibration"];
  l2b_spec_a_cfamfo [label="spec_a CFAM filter offset 1..1", shape="cds",
                 valname="clerk.calibration.l2b_spec_a.cfam_filter_offset",
                 valtype="dip.base.Calibration"];

  l3_spec_a_odir [label="Output path for L3_spec_a 1..1", shape="ellipse",
                 valname="clerk.configuration.l3_spec_a.outdir",
                 valtype="dip.base.Configuration"];
  l3_spec_a_rec [label="recipe L3_spec_a 1..1", shape="cds",
                 valname="clerk.recipe.l3_spec_a.recipe",
                 valtype="dip.base.Recipe"];
  l3_spec_a_ast [label="spec_a astrometry 1..1", shape="cds",
                 valname="clerk.calibration.l3_spec_a.astrometry",
                 valtype="dip.base.Calibration"];
  l3_spec_a_ndf [label="spec_a astrometry 1..1", shape="cds",
                 valname="clerk.calibration.l3_spec_a.ndfilter",
                 valtype="dip.base.Calibration"];
  l3_spec_a_dispm [label="spec_a dispersion model 1..1", shape="cds",
                 valname="clerk.calibration.l3_spec_a.dispersion_model",
                 valtype="dip.base.Calibration"];
  l3_spec_a_wavem [label="spec_a dispersion model 1..1", shape="cds",
                 valname="clerk.calibration.l3_spec_a.wavelength_map",
                 valtype="dip.base.Calibration"];

  l4_spec_a_odir [label="Output path for L4_spec_a 1..1", shape="ellipse",
                 valname="clerk.configuration.l4_spec_a.outdir",
                 valtype="dip.base.Configuration"];
  l4_spec_a_rec [label="recipe L4_spec_a 1..1", shape="cds",
                 valname="clerk.recipe.l4_spec_a.recipe",
                 valtype="dip.base.Recipe"];
  l4_spec_a_afcal [label="spec_a absolute flux 1..1", shape="cds",
                 valname="clerk.calibration.l4_spec_a.absolute_flux",
                 valtype="dip.base.Calibration"];
  l4_spec_a_ctcal [label="spec_a core throughput 1..1", shape="cds",
                 valname="clerk.calibration.l4_spec_a.core_thruput",
                 valtype="dip.base.Calibration"];
  l4_spec_a_ndfilt [label="spec_a ND filter 1..1", shape="cds",
                 valname="clerk.calibration.l4_spec_a.nd_filter",
                 valtype="dip.base.Calibration"];
  l4_spec_a_stmap [label="spec_a slit transmission map 1..1", shape="cds",
                 valname="clerk.calibration.l4_spec_a.slit_transmission_map",
                 valtype="dip.base.Calibration"];
  l4_spec_a_tspi [label="spec_a target star prism image 1..1", shape="cds",
                 valname="clerk.calibration.l4_spec_a.target_star_prism_image",
                 valtype="dip.base.Calibration"];
  l4_spec_a_rspi [label="spec_a reference star prism image 1..1", shape="cds",
                 valname="clerk.calibration.l4_spec_a.ref_star_prism_image",
                 valtype="dip.base.Calibration"];
  l4_spec_a_lsf [label="spec_a ND filter line spread function", shape="cds",
                 valname="clerk.calibration.l4_spec_a.line_spread_function",
                 valtype="dip.base.Calibration"];

  alarm_cal -> calib [style="dashed"];
  alarm_cnf -> config [style="dashed"];
  alarm_rec -> recipe [style="dashed"];

  calib -> l1_spec_a_nllut;
  calib -> l2a_spec_a_mbpm;
  calib -> l2a_spec_a_dnb;
  calib -> l2a_spec_a_cti;
  calib -> l2a_spec_a_ff;
  calib -> l2a_spec_a_kgain;
  calib -> l2a_spec_a_emg;
  calib -> l2b_spec_a_distm;
  calib -> l2b_spec_a_excicrf;
  calib -> l2b_spec_a_excfovps;
  calib -> l2b_spec_a_cfamfo;
  calib -> l3_spec_a_ast;
  calib -> l3_spec_a_ndf;
  calib -> l3_spec_a_dispm;
  calib -> l3_spec_a_wavem;
  calib -> l4_spec_a_afcal;
  calib -> l4_spec_a_ctcal;
  calib -> l4_spec_a_ndfilt;
  calib -> l4_spec_a_stmap;
  calib -> l4_spec_a_tspi;
  calib -> l4_spec_a_rspi;
  calib -> l4_spec_a_lsf;
  config -> l1_spec_a_odir;
  config -> l2a_spec_a_odir;
  config -> l2b_spec_a_odir;
  config -> l3_spec_a_odir;
  config -> l4_spec_a_odir;
  recipe -> l1_spec_a_rec;
  recipe -> l2a_spec_a_rec;
  recipe -> l2b_spec_a_rec;
  recipe -> l3_spec_a_rec;
  recipe -> l4_spec_a_rec;
}
