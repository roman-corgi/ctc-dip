digraph DispersionModelCalibrations {
graph [splines="ortho", rankdir=LR];
trans_cal_dpm_l1_l2a [label="DispersionModel\nTransmutation\nL1 to L2a basic", shape="circle", runname="l1.transmutation_cal_dpm", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
l1_cal_dpm_prod [label="L1_DispersionModel products 1..b", shape="rectangle"];
l1_cal_dpm_man [label="L1_DispersionModel manifest 1..1", shape="ellipse"];
l1_cal_dpm_odir [label="L1_DispersionModel output path 1..1", shape="ellipse"];
l1_cal_dpm_rec [label="L1_DispersionModel recipe 1..1", shape="cds"];
cal_dpm_prod [label="DispersionModel products 1..1", shape="rectangle"];
cal_dpm_log [label="DispersionModel log 1..1", shape="ellipse"];
cal_dpm_man [label="DispersionModel product manifest 1..1", shape="ellipse", shape="ellipse", valname="l1.transmutation_cal_dpm.product.manifest", valtype="dip.base.Manifest"];
cal_dpm_src [label="DispersionModel source manifest 1..1", shape="ellipse", valname="l1.transmutation_cal_dpm.source.manifest", valtype="dip.base.Manifest"];
l1_cal_dpm_prod -> trans_cal_dpm_l1_l2a [style="dashed"];
l1_cal_dpm_man -> trans_cal_dpm_l1_l2a;
l1_cal_dpm_odir -> trans_cal_dpm_l1_l2a;
l1_cal_dpm_rec -> trans_cal_dpm_l1_l2a;
trans_cal_dpm_l1_l2a -> cal_dpm_prod [style="dashed"];
trans_cal_dpm_l1_l2a -> cal_dpm_man;
trans_cal_dpm_l1_l2a -> cal_dpm_src;
trans_cal_dpm_l1_l2a -> cal_dpm_log [style="dashed"];
}
