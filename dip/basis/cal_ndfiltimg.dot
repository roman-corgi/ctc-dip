trans_cal_ndfiltimg_l2a_l2b [label="ND Imaging Filter\nTransmutation\nL2a to L2b", shape="circle", runname="l2a.transmutation_cal_ndfiltimg", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
