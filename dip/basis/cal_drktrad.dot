digraph DarkTraditionalCalibrations {
graph [splines="ortho", rankdir=LR];
trans_cal_drktrad_l1_l2a [label="Dark(Traditional)\nTransmutation\nL1 to L2a basic", shape="circle", runname="l1.transmutation_cal_drktrad", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
l1_cal_drktrad_prod [label="L1_Dark(Traditional) products 1..b", shape="rectangle"];
l1_cal_drktrad_man [label="L1_Dark(Traditional) manifest 1..1", shape="ellipse"];
l1_cal_drktrad_odir [label="L1_Dark(Traditional) output path 1..1", shape="ellipse"];
l1_cal_drktrad_rec [label="L1_Dark(Traditional) recipe 1..1", shape="cds"];
cal_drktrad_prod [label="Dark(Traditional) products 1..1", shape="rectangle"];
cal_drktrad_log [label="Dark(Traditional) log 1..1", shape="ellipse"];
cal_drktrad_man [label="Dark(Traditional) product manifest 1..1", shape="ellipse", shape="ellipse", valname="l1.transmutation_cal_drktrad.product.manifest", valtype="dip.base.Manifest"];
cal_drktrad_src [label="Dark(Traditional) source manifest 1..1", shape="ellipse", valname="l1.transmutation_cal_drktrad.source.manifest", valtype="dip.base.Manifest"];
l1_cal_drktrad_prod -> trans_cal_drktrad_l1_l2a [style="dashed"];
l1_cal_drktrad_man -> trans_cal_drktrad_l1_l2a;
l1_cal_drktrad_odir -> trans_cal_drktrad_l1_l2a;
l1_cal_drktrad_rec -> trans_cal_drktrad_l1_l2a;
trans_cal_drktrad_l1_l2a -> cal_drktrad_prod [style="dashed"];
trans_cal_drktrad_l1_l2a -> cal_drktrad_man;
trans_cal_drktrad_l1_l2a -> cal_drktrad_src;
trans_cal_drktrad_l1_l2a -> cal_drktrad_log [style="dashed"];
}
