digraph PolarimetryPhotonCount
{
  graph [splines="ortho", rankdir=LR];

  trans_pol_pc_l1_l2a [label="pol_pc Transmutation\nL1 to L2a", shape="circle"];
  l2a_pol_pc_demux [label="pol_pc l2a Demux\nExposure" shape="circle"];
  trans_pol_pc_l2a_l2b [label="pol_pc Transmutation\nL2a to L2b", shape="circle"];
  l2b_pol_pc_mux [label="pol_pc l2b Mux\nExposure", shape="circle"];
  trans_pol_pc_l2b_l3 [label="pol_pc Transmutation\nL2b to L3", shape="circle"];
  trans_pol_pc_l3_l4 [label="pol_pc Transmutation\nL3 to L4", shape="circle"];
  trans_pol_pc_l4_tda [label="pol_pc Transmutation\nL4 to TDA", shape="circle"];
        
  l1_pol_pc_prod [label="L1_pol_pc products 1..b", shape="rectangle"];
  l1_pol_pc_man [label="L1_pol_pc manifest 1..1", shape="ellipse"];
  l1_pol_pc_odir [label="L1_pol_pc output path 1..1", shape="ellipse"];
  l1_pol_pc_rec [label="L1_pol_pc recipe 1..1", shape="cds"];
  l1_pol_pc_nllut [label="L1_pol_pc non-linear LUT 1..1", shape="cds"];

  l2a_pol_pc_prod [label="L2a_pol_pc products 1..b", shape="rectangle"];
  l2a_pol_pc_man [label="L2a_pol_pc manifest 1..1", shape="ellipse"];
  l2a_pol_pc_odir [label="L2a_pol_pc output path 1..1", shape="ellipse"];
  l2a_pol_pc_rec [label="L2a_pol_pc recipe 1..1", shape="cds"];
  l2a_pol_pc_cti [label="L2a_pol_pc charge xfer inefficiency 1..1", shape="cds"];
  l2a_pol_pc_dnb [label="L2a_pol_pc CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
  l2a_pol_pc_mbpm [label="L2a_pol_pc master bad pixel map 1..1", shape="cds"];
  l2a_pol_pc_emg [label="L2a_pol_pc EM gain 1..1", shape="cds"];
  l2a_pol_pc_kgain [label="L2a_pol_pc Kgain 1..1", shape="cds"];
  l2a_pol_pc_polff [label="L2a_pol_pc polarimetric flat fields 1..1", shape="cds"];
  l2a_pol_pc_log [label="L2a log_pol_pc 1..1", shape="ellipse"];
  l2a_pol_pc_man_demux [label="L2a_pol_pc(E) manifest 1..1", shape="ellipse"];
  
  l2b_pol_pc_prod [label="L2b_pol_pc products 1..1", shape="rectangle"];
  l2b_pol_pc_man [label="L2b_pol_pc manifest 1..1", shape="ellipse"];
  l2b_pol_pc_odir [label="L2b_pol_pc output path 1..1", shape="ellipse"];
  l2b_pol_pc_rec [label="L2b_pol_pc recipe 1..1", shape="cds"];
  l2b_pol_pc_excicrf [label="L2b_pol_pc EXCAM ICRF location 1..1", shape="cds"];
  l2b_pol_pc_excfovps [label="L2b_pol_pc EXCAM FOV pixel scale 1..1", shape="cds"];
  l2b_pol_pc_cfamfo [label="L2b_pol_pc CFAM filter offsets 1..1", shape="cds"];
  l2b_pol_pc_man_demux [label="L2b_pol_pc(E) manifest 1..1", shape="ellipse"];
  l2b_pol_pc_log [label="L2b_pol_pc log 1..1", shape="ellipse"];

  l3_pol_pc_prod [label="L3_pol_pc products 1..1", shape="rectangle"];
  l3_pol_pc_odir [label="L3_pol_pc output path 1..1", shape="ellipse"];
  l3_pol_pc_man [label="L3_pol_pc manifest 1..1", shape="ellipse"];
  l3_pol_pc_rec [label="L3_pol_pc recipe 1..1", shape="cds"];
  l3_pol_pc_mueller [label="L3_pol_pc mueller matrix 1..1", shape="cds"];
  l3_pol_pc_log [label="L3_pol_pc log 1..1", shape="ellipse"];

  l4_pol_pc_prod [label="L4_pol_pc products 1..1", shape="rectangle"];
  l4_pol_pc_log [label="L4_pol_pc log 1..1", shape="ellipse"];
  l4_pol_pc_man [label="L4_pol_pc manifest 1..1", shape="ellipse"];
  l4_pol_pc_odir [label="L4_pol_pc output path 1..1", shape="ellipse"];
  l4_pol_pc_rec [label="L4_pol_pc recipe 1..1", shape="cds"];
  l4_pol_pc_ctcal [label="L4_pol_pc core throughput calibrations 1..1", shape="cds"];
  l4_pol_pc_pafcal [label="L4_pol_pc polarimetric absolute flux calibration 1..1", shape="cds"];

  l1_pol_pc_prod -> trans_pol_pc_l1_l2a;
  l1_pol_pc_man -> trans_pol_pc_l1_l2a;
  l1_pol_pc_odir -> trans_pol_pc_l1_l2a;
  l1_pol_pc_rec -> trans_pol_pc_l1_l2a;
  l1_pol_pc_nllut -> trans_pol_pc_l1_l2a;

  trans_pol_pc_l1_l2a -> l2a_pol_pc_prod;
  trans_pol_pc_l1_l2a -> l2a_pol_pc_man;  
  trans_pol_pc_l1_l2a -> l2a_pol_pc_log;  

  l2a_pol_pc_prod -> trans_pol_pc_l2a_l2b;
  l2a_pol_pc_odir -> trans_pol_pc_l2a_l2b;
  l2a_pol_pc_rec -> trans_pol_pc_l2a_l2b;
  l2a_pol_pc_cti -> trans_pol_pc_l2a_l2b [style="dashed"];
  l2a_pol_pc_dnb -> trans_pol_pc_l2a_l2b;
  l2a_pol_pc_mbpm -> trans_pol_pc_l2a_l2b;
  l2a_pol_pc_emg -> trans_pol_pc_l2a_l2b;
  l2a_pol_pc_kgain -> trans_pol_pc_l2a_l2b;
  l2a_pol_pc_polff -> trans_pol_pc_l2a_l2b;

  trans_pol_pc_l2a_l2b -> l2b_pol_pc_prod;
  trans_pol_pc_l2a_l2b -> l2b_pol_pc_man_demux;
  trans_pol_pc_l2a_l2b -> l2b_pol_pc_log;

  l2a_pol_pc_man -> l2a_pol_pc_demux;
  l2a_pol_pc_demux -> l2a_pol_pc_man_demux;
  l2a_pol_pc_man_demux -> trans_pol_pc_l2a_l2b;
  
  l2b_pol_pc_man_demux -> l2b_pol_pc_mux;
  l2b_pol_pc_mux -> l2b_pol_pc_man;
  
  l2b_pol_pc_prod -> trans_pol_pc_l2b_l3;
  l2b_pol_pc_man -> trans_pol_pc_l2b_l3;
  l2b_pol_pc_odir -> trans_pol_pc_l2b_l3;
  l2b_pol_pc_rec -> trans_pol_pc_l2b_l3;
  l2b_pol_pc_excicrf -> trans_pol_pc_l2b_l3;
  l2b_pol_pc_excfovps -> trans_pol_pc_l2b_l3;
  l2b_pol_pc_cfamfo -> trans_pol_pc_l2b_l3;
  trans_pol_pc_l2b_l3 -> l3_pol_pc_prod;
  trans_pol_pc_l2b_l3 -> l3_pol_pc_man;  
  trans_pol_pc_l2b_l3 -> l3_pol_pc_log;  

  l3_pol_pc_prod -> trans_pol_pc_l3_l4;
  l3_pol_pc_man -> trans_pol_pc_l3_l4;
  l3_pol_pc_odir -> trans_pol_pc_l3_l4;
  l3_pol_pc_rec -> trans_pol_pc_l3_l4;
  l3_pol_pc_mueller -> trans_pol_pc_l3_l4;
  trans_pol_pc_l3_l4 -> l4_pol_pc_prod;
  trans_pol_pc_l3_l4 -> l4_pol_pc_log;
  trans_pol_pc_l3_l4 -> l4_pol_pc_man;

  l4_pol_pc_prod -> trans_pol_pc_l4_tda;
  l4_pol_pc_man -> trans_pol_pc_l4_tda;
  l4_pol_pc_odir -> trans_pol_pc_l4_tda;
  l4_pol_pc_rec -> trans_pol_pc_l4_tda;
  l4_pol_pc_ctcal -> trans_pol_pc_l4_tda;
  l4_pol_pc_pafcal -> trans_pol_pc_l4_tda;
  trans_pol_pc_l4_tda -> tda_pol_pc_prod;
  trans_pol_pc_l4_tda -> tda_pol_pc_log;
}
