/* why separate channels and how are they tied back together
*
* The magic happens from clerks.dot. It contains the same clerks but with dawgie
* information tied to the nodes. Since they are all named the same among these
* channlized files and clerks.dot, the dip.basis.transmute distills then
* condenses them into a hidden monolithic concept if they have dawgie
* information associated with them. That is the real magic.
*/
digraph PolPCClerks
{
  graph [splines="ortho", rankdir=LR];

  alarm_cal [label="User requested update", shape="none"];
  alarm_cnf [label="User requested update", shape="none"];
  alarm_rec [label="User requested update", shape="none"];
  
  calib [label="Calibration", shape="circle"];
  config [label="Configuration", shape="circle"];
  recipe [label="Recipe", shape="circle"];

  l1_pol_pc_odir [label="Output path for L1_pol_pc 1..1", shape="ellipse",
                 valname="clerk.configuration.l1_pol_pc.outdir",
                 valtype="dip.base.Configuration"];
  l1_pol_pc_rec [label="recipe L1_pol_pc 1..1", shape="cds",
                valname="clerk.recipe.l1_pol_pc.recipe",
                valtype="dip.base.Recipe"];
  l1_pol_pc_nllut [label="non linear calibration 1..1", shape="cds",
                     valname="clerk.calibration.l1_pol_pc.nonlin",
                     valtype="dip.base.Calibration"];

  l2a_pol_pc_odir [label="Output path for L2a_pol_pc 1..1", shape="ellipse",
                 valname="clerk.configuration.l2a_pol_pc.outdir",
                 valtype="dip.base.Configuration"];
  l2a_pol_pc_rec [label="recipe L2a_pol_pc 1..1", shape="cds",
                 valname="clerk.recipe.l2a_pol_pc.recipe",
                 valtype="dip.base.Recipe"];
  l2a_pol_pc_mbpm [label="pol_pc bad pixel map 1..1", shape="cds",
                valname="clerk.calibration.l2a_pol_pc.bad_pix_map",
                valtype="dip.base.Calibration"];
  l2a_pol_pc_dnb  [label="pol_pc dark (CIC/FPN/dark current) 1..1", shape="cds",
                  valname="clerk.calibration.l2a_pol_pc.darks",
                  valtype="dip.base.Calibration"];
  l2a_pol_pc_cti  [label="pol_pc charge transfer efficiency 1..1", shape="cds",
                valname="clerk.calibration.l2a_pol_pc.charge_xfer_eff",
                valtype="dip.base.Calibration"];
  l2a_pol_pc_polff  [label="pol_pc flat field 1..1", shape="cds",
                valname="clerk.calibration.l2a_pol_pc.flat_field",
                valtype="dip.base.Calibration"];
  l2a_pol_pc_kgain  [label="pol_pc k-gain 1..1", shape="cds",
                valname="clerk.calibration.l2a_pol_pc.k_gain",
                valtype="dip.base.Calibration"];
  l2a_pol_pc_emg [label="pol_pc EM gain 1..1", shape="cds",
                valname="clerk.calibration.l2a_pol_pc.em_gain",
                valtype="dip.base.Calibration"];
  l2b_pol_pc_odir [label="Output path for L2b_pol_pc 1..1", shape="ellipse",
                 valname="clerk.configuration.l2b_pol_pc.outdir",
                 valtype="dip.base.Configuration"];
  l2b_pol_pc_rec [label="recipe L2b_pol_pc 1..1", shape="cds",
                 valname="clerk.recipe.l2b_pol_pc.recipe",
                 valtype="dip.base.Recipe"];
  l2b_pol_pc_distm [label="pol_pc distortion map 1..1", shape="cds",
                 valname="clerk.calibration.l2b_pol_pc.distortion_map",
                 valtype="dip.base.Calibration"];
  l2b_pol_pc_excicrf [label="pol_pc EXCAM ICRF location 1..1", shape="cds",
                 valname="clerk.calibration.l2b_pol_pc.excam_icrf_location",
                 valtype="dip.base.Calibration"];
  l2b_pol_pc_excfovps [label="pol_pc ECAM FOV pixel scale 1..1", shape="cds",
                 valname="clerk.calibration.l2b_pol_pc.excam_fov_pixel_scale",
                 valtype="dip.base.Calibration"];
  l2b_pol_pc_cfamfo [label="spec_a CFAM filter offset 1..1", shape="cds",
                 valname="clerk.calibration.l2b_pol_pc.cfam_filter_offset",
                 valtype="dip.base.Calibration"];

  l3_pol_pc_odir [label="Output path for L3_pol_pc 1..1", shape="ellipse",
                 valname="clerk.configuration.l3_pol_pc.outdir",
                 valtype="dip.base.Configuration"];
  l3_pol_pc_rec [label="recipe L3_pol_pc 1..1", shape="cds",
                 valname="clerk.recipe.l3_pol_pc.recipe",
                 valtype="dip.base.Recipe"];
  l3_pol_pc_ast [label="pol_pc astrometry 1..1", shape="cds",
                 valname="clerk.calibration.l3_pol_pc.astrometry",
                 valtype="dip.base.Calibration"];
  l3_pol_pc_ndf [label="pol_pc astrometry 1..1", shape="cds",
                 valname="clerk.calibration.l3_pol_pc.ndfilter",
                 valtype="dip.base.Calibration"];
  l3_pol_pc_mueller [label="pol_pc mueller 1..1", shape="cds",
                 valname="clerk.calibration.l3_pol_pc.mueller_matrix",
                 valtype="dip.base.Calibration"];

  l4_pol_pc_odir [label="Output path for L4_pol_pc 1..1", shape="ellipse",
                 valname="clerk.configuration.l4_pol_pc.outdir",
                 valtype="dip.base.Configuration"];
  l4_pol_pc_rec [label="recipe L4_pol_pc 1..1", shape="cds",
                 valname="clerk.recipe.l4_pol_pc.recipe",
                 valtype="dip.base.Recipe"];
  l4_pol_pc_afcal [label="pol_pc absolute flux 1..1", shape="cds",
                 valname="clerk.calibration.l4_pol_pc.absolute_flux",
                 valtype="dip.base.Calibration"];
  l4_pol_pc_ctcal [label="pol_pc core throughput 1..1", shape="cds",
                 valname="clerk.calibration.l4_pol_pc.core_thruput",
                 valtype="dip.base.Calibration"];
  l4_pol_pc_ndfilt [label="pol_pc ND filter 1..1", shape="cds",
                 valname="clerk.calibration.l4_pol_pc.nd_filter",
                 valtype="dip.base.Calibration"];

  alarm_cal -> calib [style="dashed"];
  alarm_cnf -> config [style="dashed"];
  alarm_rec -> recipe [style="dashed"];

  calib -> l1_pol_pc_nllut;
  calib -> l2a_pol_pc_mbpm;
  calib -> l2a_pol_pc_dnb;
  calib -> l2a_pol_pc_cti;
  calib -> l2a_pol_pc_polff;
  calib -> l2a_pol_pc_kgain;
  calib -> l2a_pol_pc_emg;
  calib -> l2b_pol_pc_distm;
  calib -> l2b_pol_pc_excicrf;
  calib -> l2b_pol_pc_excfovps;
  calib -> l2b_pol_pc_cfamfo;
  calib -> l3_pol_pc_ast;
  calib -> l3_pol_pc_mueller;
  calib -> l3_pol_pc_ndf;
  calib -> l4_pol_pc_afcal;
  calib -> l4_pol_pc_ctcal;
  calib -> l4_pol_pc_ndfilt;
  config -> l1_pol_pc_odir;
  config -> l2a_pol_pc_odir;
  config -> l2b_pol_pc_odir;
  config -> l3_pol_pc_odir;
  config -> l4_pol_pc_odir;
  recipe -> l1_pol_pc_rec;
  recipe -> l2a_pol_pc_rec;
  recipe -> l2b_pol_pc_rec;
  recipe -> l3_pol_pc_rec;
  recipe -> l4_pol_pc_rec;
}
