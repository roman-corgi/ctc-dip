/* why this file
*
* This file exists because all of the channelized pictures use these dawgie
* information to connect to. The builder for DIP wants the dawgie information
* to be defined once. Having a monolithic graphviz file makes it an unreadable
* eye chart. So, broke the information into each of their own channels and this
* one to tie them together in dawgie.
*/
digraph Clerks
{
  graph [splines="ortho", rankdir=LR];

  alarm_cal [label="User reqyested update", shape="none"];
  alarm_cnf [label="User reqyested update", shape="none"];
  alarm_rec [label="User requsted update", shape="none"];
  
  calib [label="Calibration", shape="circle",
         runname="clerk.calibration"
         runtype="dawgie.Analyzer"
         fsmtype="dip.clerk.impls.calibration.FSM"];
  config [label="Configuration", shape="circle",
          runname="clerk.configuration",
          runtype="dawgie.Analyzer",
          fsmtype="dip.clerk.impls.config.FSM"];
  recipe [label="Recipe", shape="circle",
          runname="clerk.recipe"
          runtype="dawgie.Analyzer"
          fsmtype="dip.clerk.impls.recipe.FSM"];

  alarm_cal -> calib [style="dashed"];
  alarm_cnf -> calib [style="dashed"];
  alarm_rec -> recipe [style="dashed"];
}
