digraph Throughput {
    graph [splines="ortho", rankdir=LR];

    trans_cal_corethpt [label="L1\nTransmutation\nCoreThroughput", shape="circle", runname="l1.transmutation_cal_corethpt", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];

    l1_cal_corethpt_odir [label="L1_Throughput output path 1..1", shape="ellipse"];
    l1_cal_corethpt_rec [label="L1 Throughput recipe 1..1", shape="cds"];

    l1_cal_corethpt_nllut [label="L1_Throughput non-linear LUT 1..1", shape="cds"];

    l2a_cal_corethpt_cti [label="L2a_Throughput charge xfer inefficiency 1..1", shape="cds"];
    l2a_cal_corethpt_dnb [label="L2a_Throughput CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
    l2a_cal_corethpt_mbpm [label="L2a_Throughput master bad pixel map 1..1", shape="cds"];
    l2a_cal_corethpt_ff [label="L2a_Throughput flat fields 1..1", shape="cds"];
    l2a_cal_corethpt_emg [label="L2a_Throughput EM gain 1..1", shape="cds"];
    l2a_cal_corethpt_kgain [label="L2_Throughput Kgain 1..1", shape="cds"];


    cal_corethpt_prod [label="CoreThroughput products 1..1", shape="rectangle"];
    cal_corethpt_log [label="CoreThroughput log 1..1", shape="ellipse"];
    cal_corethpt_man [label="CoreThroughput product manifest 1..1", shape="ellipse", shape="ellipse", valname="l1.transmutation_cal_corethpt.product.manifest", valtype="dip.base.Manifest"];
    cal_corethpt_src [label="CoreThroughput source manifest 1..1", shape="ellipse", shape="ellipse", valname="l1.transmutation_cal_corethpt.source.manifest", valtype="dip.base.Manifest"];


    l1_cal_corethpt_prod -> trans_cal_corethpt [style="dashed"];
    l1_cal_corethpt_man -> trans_cal_corethpt;
    l1_cal_corethpt_odir -> trans_cal_corethpt;
    l1_cal_corethpt_rec -> trans_cal_corethpt;
    l1_cal_corethpt_nllut -> trans_cal_corethpt;

    l2a_cal_corethpt_kgain -> trans_cal_corethpt;
    l2a_cal_corethpt_cti -> trans_cal_corethpt;
    l2a_cal_corethpt_dnb -> trans_cal_corethpt;
    l2a_cal_corethpt_mbpm -> trans_cal_corethpt;
    l2a_cal_corethpt_ff -> trans_cal_corethpt;
    l2a_cal_corethpt_emg -> trans_cal_corethpt;

    trans_cal_corethpt -> cal_corethpt_man;
    trans_cal_corethpt -> cal_corethpt_src;
    trans_cal_corethpt -> cal_corethpt_log [style="dashed"];
    trans_cal_corethpt -> cal_corethpt_prod [style="dashed"];
}
