digraph Throughput
{
  graph [splines="ortho", rankdir=LR];

  trans_corethpt_l1_l2a [label="Throughput\nTransmutation\nL1 to L2a basic", shape="circle"];
  trans_corethpt_l2a_l2b [label="Throughput\nTransmutation\nL2a to L2b", shape="circle"];
  trans_corethpt_l2b_ctp [label="Throughput\nTransmutation\nL2b to CoreThroughput", shape="circle"];
        
  l1_corethpt_prod [label="L1_Throughput products 1..b", shape="rectangle"];
  l1_corethpt_man [label="L1_Throughput manifest 1..1", shape="ellipse"];
  l1_corethpt_odir [label="L1_Throughput output path 1..1", shape="ellipse"];
  l1_corethpt_rec [label="L1_Throughput recipe 1..1", shape="cds"];
  l1_corethpt_nllut [label="L1_Throughput non-linear LUT 1..1", shape="cds"];

  l2a_corethpt_prod [label="L2a_Throughput products 1..b", shape="rectangle"];
  l2a_corethpt_man [label="L2a_Throughput manifest 1..1", shape="ellipse"];
  l2a_corethpt_odir [label="L2a_Throughput output path 1..1", shape="ellipse"];
  l2a_corethpt_rec [label="L2a_Throughput recipe 1..1", shape="cds"];
  l2a_corethpt_cti [label="L2a_Throughput charge xfer inefficiency 1..1", shape="cds"];
  l2a_corethpt_dnb [label="L2a_Throughput CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
  l2a_corethpt_mbpm [label="L2a_Throughput master bad pixel map 1..1", shape="cds"];
  l2a_corethpt_ff [label="L2a_Throughput flat fields 1..1", shape="cds"];
  l2a_corethpt_emg [label="L2a_Throughput EM gain 1..1", shape="cds"];
  l2a_corethpt_kgain [label="L2_Throughput Kgain 1..1", shape="cds"];
  l2a_corethpt_log [label="L2a_Throughput log 1..1", shape="ellipse"];
  
  l2b_corethpt_prod [label="L2b_Throughput products 1..1", shape="rectangle"];
  l2b_corethpt_man [label="L2b_Throughput manifest 1..1", shape="ellipse"];
  l2b_corethpt_odir [label="L2b_Throughput output path 1..1", shape="ellipse"];
  l2b_corethpt_rec [label="L2b_Throughput recipe 1..1", shape="cds"];
  l2b_corethpt_excicrf [label="L2b_Throughput EXCAM ICRF location 1..1", shape="cds"];
  l2b_corethpt_excfovps [label="L2b_Throughput EXCAM FOV pixel scale 1..1", shape="cds"];
  l2b_corethpt_distm [label="L2b_Throughput distortion map 1..1", shape="cds"];
  l2b_corethpt_log [label="L2b_Throughput log 1..1", shape="ellipse"];

  ctp_prod [label="CoreThroughput products 1..1", shape="rectangle"];
  ctp_log [label="CoreThroughput log 1..1", shape="ellipse"];
  ctp_man [label="CoreThroughput manifest 1..1", shape="ellipse"];

  l1_corethpt_prod -> trans_corethpt_l1_l2a [style="dashed"];
  l1_corethpt_man -> trans_corethpt_l1_l2a;
  l1_corethpt_odir -> trans_corethpt_l1_l2a;
  l1_corethpt_rec -> trans_corethpt_l1_l2a;
  l1_corethpt_nllut -> trans_corethpt_l1_l2a;

  trans_corethpt_l1_l2a -> l2a_corethpt_prod [style="dashed"];
  trans_corethpt_l1_l2a -> l2a_corethpt_man;  
  trans_corethpt_l1_l2a -> l2a_corethpt_log [style="dashed"];  

  l2a_corethpt_prod -> trans_corethpt_l2a_l2b [style="dashed"];
  l2a_corethpt_kgain -> trans_corethpt_l2a_l2b;
  l2a_corethpt_odir -> trans_corethpt_l2a_l2b;
  l2a_corethpt_rec -> trans_corethpt_l2a_l2b;
  l2a_corethpt_cti -> trans_corethpt_l2a_l2b;
  l2a_corethpt_dnb -> trans_corethpt_l2a_l2b;
  l2a_corethpt_mbpm -> trans_corethpt_l2a_l2b;
  l2a_corethpt_ff -> trans_corethpt_l2a_l2b;
  l2a_corethpt_emg -> trans_corethpt_l2a_l2b;
  l2a_corethpt_man -> trans_corethpt_l2a_l2b;

  trans_corethpt_l2a_l2b -> l2b_corethpt_prod [style="dashed"];
  trans_corethpt_l2a_l2b -> l2b_corethpt_log [style="dashed"];
  trans_corethpt_l2a_l2b -> l2b_corethpt_man;
  
  l2b_corethpt_prod -> trans_corethpt_l2b_ctp [style="dashed"];
  l2b_corethpt_man -> trans_corethpt_l2b_ctp;
  l2b_corethpt_odir -> trans_corethpt_l2b_ctp;
  l2b_corethpt_rec -> trans_corethpt_l2b_ctp;
  l2b_corethpt_excicrf -> trans_corethpt_l2b_ctp;
  l2b_corethpt_excfovps -> trans_corethpt_l2b_ctp;
  l2b_corethpt_distm -> trans_corethpt_l2b_ctp;
  trans_corethpt_l2b_ctp -> ctp_prod [style="dashed"];
  trans_corethpt_l2b_ctp -> ctp_log [style="dashed"];  
  trans_corethpt_l2b_ctp -> ctp_man;
}
