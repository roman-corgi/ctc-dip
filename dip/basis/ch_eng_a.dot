digraph Channel_eng_a_Design
{
  graph [splines="ortho", rankdir=LR];

  trans_eng_a_l1_l2a [label="Transmutation\nL1 to L2a", shape="circle",
                      runname="l1.transmutation_eng_a"
                      runtype="dawgie.Algorithm"
                      fsmtype="dip.base.Runner"];
  trans_eng_a_l2a_l2b [label="Transmutation\nL2a to L2b", shape="circle",
                       runname="l2a.transmutation_eng_a",
                       runtype="dawgie.Algorithm"
                       fsmtype="dip.base.Runner"];
  l2_eng_a_demux [label="demux", shape="circle"
                  runname="l2a.demux_eng_a"
                  runtype="dawgie.Algorithm"
                  fsmtype="dip.clerk.impls.demux.FSM"]
  l2_eng_a_mux [label="mux", shape="circle"
                runname="l2b.mux_eng_a"
                runtype="dawgie.Analyzer"
                fsmtype="dip.clerk.impls.mux.FSM"]
        
  l1_eng_a_prod [label="L1_eng_a products 1..b", shape="rectangle"];
  l1_eng_a_man [label="L1_eng_a manifest 1..1", shape="ellipse"];
  eng_a_cpgs [label="eng_a CPGS 1..1", shape="cds"];
  l1_eng_a_odir [label="L1_eng_a output path 1..1", shape="ellipse"];
  l1_eng_a_rec [label="recipe 1..1", shape="cds"];
  l1_eng_a_nln [label="non linear calibration 1..1", shape="cds"];

  l2a_eng_a_man [label="L2a_eng_a manifest 1..1", shape="ellipse"
                 valname="l1.transmutation_eng_a.product.manifest"
                 valtype="dip.base.Manifest"];
  l2a_eng_a_man_demux [label="L2a_eng_a(E) manifest 1..1", shape="ellipse"
                       valname="l2a.demux_eng_a.product.manifest"
                       valtype="dip.base.Manifest"];
  l2a_eng_a_log [label="L2a_eng_a log 1..1", shape="ellipse"];
  l2a_eng_a_prod [label="L2a products 1..b", shape="rectangle"];
  l2a_eng_a_odir [label="L2a_eng_a output path 1..1", shape="ellipse"];
  l2a_eng_a_rec [label="recipe 1..1", shape="cds"];
  l2a_eng_a_bpm [label="bad pixel map 1..1", shape="cds"];
  l2a_eng_a_dt  [label="dark (traditional) 1..1", shape="cds"];
  l2a_eng_a_ds  [label="dark (synthetized) 1..1", shape="cds"];
  l2a_eng_a_dn  [label="dark (from noise map) 1..1", shape="cds"];
  l2a_eng_a_nm  [label="noise maps 1..1", shape="cds"];
  l2a_eng_a_ff  [label="flat field 1..1", shape="cds"];
  l2a_eng_a_kg  [label="k-gain 1..1", shape="cds"];
  l2a_eng_a_emg [label="EM gain 1..1", shape="cds"];

  l2b_eng_a_man [label="L2b manifest 1..1", shape="ellipse"
                 valname="l2b.mux_eng_a.product.manifest",
                 valtype="dip.base.Manifest"];
  l2b_eng_a_man_demux [label="L2b(E) manifest 1..1", shape="ellipse"
                 valname="l2a.transmutation_eng_a.product.manifest",
                 valtype="dip.base.Manifest"];
  l2b_eng_a_prod [label="L2b products 1..b", shape="rectangle"];
  l2b_eng_a_log [label="L2b_eng_a log 1..1", shape="ellipse"];

  l1_eng_a_prod -> trans_eng_a_l1_l2a [style="dashed"];
  l1_eng_a_man -> trans_eng_a_l1_l2a;
  eng_a_cpgs -> trans_eng_a_l1_l2a;
  l1_eng_a_odir -> trans_eng_a_l1_l2a;
  l1_eng_a_rec -> trans_eng_a_l1_l2a;
  l1_eng_a_nln -> trans_eng_a_l1_l2a;

  trans_eng_a_l1_l2a -> l2a_eng_a_prod [style="dashed"];
  trans_eng_a_l1_l2a -> l2a_eng_a_log [style="dashed"];
  trans_eng_a_l1_l2a -> l2a_eng_a_man;

  l2a_eng_a_prod -> trans_eng_a_l2a_l2b [style="dashed"];
  l2a_eng_a_man -> l2_eng_a_demux;
  l2_eng_a_demux -> l2a_eng_a_man_demux;
  l2a_eng_a_man_demux -> trans_eng_a_l2a_l2b;
  eng_a_cpgs -> trans_eng_a_l2a_l2b;
  l2a_eng_a_odir -> trans_eng_a_l2a_l2b;
  l2a_eng_a_rec -> trans_eng_a_l2a_l2b;
  l2a_eng_a_bpm -> trans_eng_a_l2a_l2b;
  l2a_eng_a_dt -> trans_eng_a_l2a_l2b;
  l2a_eng_a_ds -> trans_eng_a_l2a_l2b;
  l2a_eng_a_dn -> trans_eng_a_l2a_l2b;
  l2a_eng_a_nm -> trans_eng_a_l2a_l2b;
  l2a_eng_a_ff -> trans_eng_a_l2a_l2b;
  l2a_eng_a_kg -> trans_eng_a_l2a_l2b;
  l2a_eng_a_emg -> trans_eng_a_l2a_l2b;

  trans_eng_a_l2a_l2b -> l2b_eng_a_prod [style="dashed"];
  trans_eng_a_l2a_l2b -> l2b_eng_a_log [style="dashed"];
  trans_eng_a_l2a_l2b -> l2b_eng_a_man_demux;
  l2b_eng_a_man_demux -> l2_eng_a_mux;
  l2_eng_a_mux -> l2b_eng_a_man;
}
