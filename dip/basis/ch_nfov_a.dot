  l2b_nfov_a_rec [label="L2b_nfov_a recipe 1..1", shape="cds"];
  l2b_nfov_a_excicrf [label="L2b_nfov_a EXCAM ICRF location 1..1", shape="cds"];
  l2b_nfov_a_excfovps [label="L2b_nfov_a EXCAM FOV pixel scale 1..1", shape="cds"];
