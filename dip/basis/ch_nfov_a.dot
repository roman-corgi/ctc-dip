  l2a_nfov_a_dnb -> trans_nfov_a_l2a_l2b;
  l2a_nfov_a_mbpm -> trans_nfov_a_l2a_l2b;
  l2a_nfov_a_ff -> trans_nfov_a_l2a_l2b;
