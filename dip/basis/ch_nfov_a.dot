  l2b_nfov_a_man -> trans_nfov_a_l2b_l3;
  l2b_nfov_a_odir -> trans_nfov_a_l2b_l3;
  l2b_nfov_a_rec -> trans_nfov_a_l2b_l3;
  l2b_nfov_a_excicrf -> trans_nfov_a_l2b_l3;
  l2b_nfov_a_excfovps -> trans_nfov_a_l2b_l3;
  l2b_nfov_a_distm -> trans_nfov_a_l2b_l3;
