  trans_nfov_a_l2b_l3 -> l3_nfov_a_man;  
  trans_nfov_a_l2b_l3 -> l3_nfov_a_log;  

  l3_nfov_a_prod -> trans_nfov_a_l3_l4;
  l3_nfov_a_man -> trans_nfov_a_l3_l4;
  l3_nfov_a_odir -> trans_nfov_a_l3_l4;
  l3_nfov_a_rec -> trans_nfov_a_l3_l4;
  l3_nfov_a_cal -> trans_nfov_a_l3_l4;
  trans_nfov_a_l3_l4 -> l4_nfov_a_prod;
  trans_nfov_a_l3_l4 -> l4_nfov_a_log;
  trans_nfov_a_l3_l4 -> l4_nfov_a_man;

  l4_nfov_a_prod -> trans_nfov_a_l4_tda;
  l4_nfov_a_man -> trans_nfov_a_l4_tda;
  l4_nfov_a_odir -> trans_nfov_a_l4_tda;
  l4_nfov_a_rec -> trans_nfov_a_l4_tda;
  l4_nfov_a_afcal -> trans_nfov_a_l4_tda;
  l4_nfov_a_ctcal -> trans_nfov_a_l4_tda;
  l4_nfov_a_ndfilt -> trans_nfov_a_l4_tda;
