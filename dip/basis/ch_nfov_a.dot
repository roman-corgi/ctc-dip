digraph NarrowFieldOfViewAnalog
{
  graph [splines="ortho", rankdir=LR];

  trans_nfov_a_l1_l2a [label="nfov_a Transmutation\nL1 to L2a", shape="circle"];
  l2a_nfov_a_demux [label="nfov_a l2a Demux\nExposure" shape="circle"];
  trans_nfov_a_l2a_l2b [label="nfov_a Transmutation\nL2a to L2b", shape="circle"];
