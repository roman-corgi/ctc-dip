  l2a_nfov_a_rec [label="L2a_nfov_a recipe 1..1", shape="cds"];
  l2a_nfov_a_cti [label="L2a_nfov_a charge xfer inefficiency 1..1", shape="cds"];
  l2a_nfov_a_dnb [label="L2a_nfov_a CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
  l2a_nfov_a_mbpm [label="L2a_nfov_a master bad pixel map 1..1", shape="cds"];
  l2a_nfov_a_ff [label="L2a_nfov_a flat fields 1..1", shape="cds"];
  l2a_nfov_a_emg [label="L2a_nfov_a EM gain 1..1", shape="cds"];
