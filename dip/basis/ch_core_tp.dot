digraph Throughput
{
  graph [splines="ortho", rankdir=LR];

  trans_tp_l1_l2a_basic [label="Throughput\nTransmutation\nL1 to L2a basic", shape="circle"];
  l2a_tp_demux [label="Throughput\nl2a Demux\nExposure" shape="circle"];
  trans_tp_l2a_l2b [label="Throughput\nTransmutation\nL2a to L2b", shape="circle"];
  l2b_tp_mux [label="Throughput\nl2b Mux\nExposure", shape="circle"];
  trans_tp_l2b_ctp [label="Throughput\nTransmutation\nL2b to CoreThroughput", shape="circle"];
        
  l1_tp_prod [label="L1_Throughput products 1..b", shape="rectangle"];
  l1_tp_man [label="L1_Throughput manifest 1..1", shape="ellipse"];
  l1_tp_odir [label="L1_Throughput output path 1..1", shape="ellipse"];
  l1_tp_rec [label="L1_Throughput recipe 1..1", shape="cds"];
  l1_tp_nllut [label="L1_Throughput non-linear LUT 1..1", shape="cds"];

  l2a_tp_prod [label="L2a_Throughput products 1..b", shape="rectangle"];
  l2a_tp_man [label="L2a_Throughput manifest 1..1", shape="ellipse"];
  l2a_tp_odir [label="L2a_Throughput output path 1..1", shape="ellipse"];
  l2a_tp_rec [label="L2a_Throughput recipe 1..1", shape="cds"];
  l2a_tp_cti [label="L2a_Throughput charge xfer inefficiency 1..1", shape="cds"];
  l2a_tp_dnb [label="L2a_Throughput CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
  l2a_tp_mbpm [label="L2a_Throughput master bad pixel map 1..1", shape="cds"];
  l2a_tp_ff [label="L2a_Throughput flat fields 1..1", shape="cds"];
  l2a_tp_emg [label="L2a_Throughput EM gain 1..1", shape="cds"];
  l2a_tp_kgain [label="L2_Throughput Kgain 1..1", shape="cds"];
  l2a_tp_log [label="L2a_Throughput log 1..1", shape="ellipse"];
  l2a_tp_man_demux [label="L2a_tp(E) manifest 1..1", shape="ellipse"];
  
  l2b_tp_prod [label="L2b_Throughput products 1..1", shape="rectangle"];
  l2b_tp_man [label="L2b_Throughput manifest 1..1", shape="ellipse"];
  l2b_tp_odir [label="L2b_Throughput output path 1..1", shape="ellipse"];
  l2b_tp_rec [label="L2b_Throughput recipe 1..1", shape="cds"];
  l2b_tp_excicrf [label="L2b_Throughput EXCAM ICRF location 1..1", shape="cds"];
  l2b_tp_excfovps [label="L2b_Throughput EXCAM FOV pixel scale 1..1", shape="cds"];
  l2b_tp_distm [label="L2b_Throughput distortion map 1..1", shape="cds"];
  l2b_tp_man_demux [label="L2b_tp(E) manifest 1..1", shape="ellipse"];
  l2b_tp_log [label="L2b_Throughput log 1..1", shape="ellipse"];

  ctp_prod [label="CoreThroughput products 1..1", shape="rectangle"];
  ctp_log [label="CoreThroughput log 1..1", shape="ellipse"];

  l1_tp_prod -> trans_tp_l1_l2a_basic;
  l1_tp_man -> trans_tp_l1_l2a_basic;
  l1_tp_odir -> trans_tp_l1_l2a_basic;
  l1_tp_rec -> trans_tp_l1_l2a_basic;
  l1_tp_nllut -> trans_tp_l1_l2a_basic;

  trans_tp_l1_l2a_basic -> l2a_tp_prod;
  trans_tp_l1_l2a_basic -> l2a_tp_man;  
  trans_tp_l1_l2a_basic -> l2a_tp_log;  

  l2a_tp_prod -> trans_tp_l2a_l2b;
  l2a_tp_kgain -> trans_tp_l2a_l2b;
  l2a_tp_odir -> trans_tp_l2a_l2b;
  l2a_tp_rec -> trans_tp_l2a_l2b;
  l2a_tp_cti -> trans_tp_l2a_l2b [style="dashed"];
  l2a_tp_dnb -> trans_tp_l2a_l2b;
  l2a_tp_mbpm -> trans_tp_l2a_l2b;
  l2a_tp_ff -> trans_tp_l2a_l2b;
  l2a_tp_emg -> trans_tp_l2a_l2b;

  trans_tp_l2a_l2b -> l2b_tp_prod;
  trans_tp_l2a_l2b -> l2b_tp_man_demux;
  trans_tp_l2a_l2b -> l2b_tp_log;

  l2a_tp_man -> l2a_tp_demux;
  l2a_tp_demux -> l2a_tp_man_demux;
  l2a_tp_man_demux -> trans_tp_l2a_l2b;
  
  l2b_tp_man_demux -> l2b_tp_mux;
  l2b_tp_mux -> l2b_tp_man;
  
  l2b_tp_prod -> trans_tp_l2b_ctp;
  l2b_tp_man -> trans_tp_l2b_ctp;
  l2b_tp_odir -> trans_tp_l2b_ctp;
  l2b_tp_rec -> trans_tp_l2b_ctp;
  l2b_tp_excicrf -> trans_tp_l2b_ctp;
  l2b_tp_excfovps -> trans_tp_l2b_ctp;
  l2b_tp_distm -> trans_tp_l2b_ctp;
  trans_tp_l2b_ctp -> ctp_prod;
  trans_tp_l2b_ctp -> ctp_log;  

}
