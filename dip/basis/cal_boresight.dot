digraph Astrometric
{
  graph [splines="ortho", rankdir=LR];

  trans_boresight_l1_l2a [label="Astrometric\nTransmutation\nL1 to L2a basic", shape="circle"];
  trans_boresight_l2a_l2b [label="Astrometric\nTransmutation\nL2a to L2b", shape="circle"];
  trans_boresight_l2b_aboresight [label="Astrometric\nTransmutation\nL2b to CoreAstrometric", shape="circle"];
        
  l1_boresight_prod [label="L1_Astrometric products 1..b", shape="rectangle"];
  l1_boresight_man [label="L1_Astrometric manifest 1..1", shape="ellipse"];
  l1_boresight_odir [label="L1_Astrometric output path 1..1", shape="ellipse"];
  l1_boresight_rec [label="L1_Astrometric recipe 1..1", shape="cds"];
  l1_boresight_nllut [label="L1_Astrometric non-linear LUT 1..1", shape="cds"];

  l2a_boresight_prod [label="L2a_Astrometric products 1..b", shape="rectangle"];
  l2a_boresight_man [label="L2a_Astrometric manifest 1..1", shape="ellipse"];
  l2a_boresight_odir [label="L2a_Astrometric output path 1..1", shape="ellipse"];
  l2a_boresight_rec [label="L2a_Astrometric recipe 1..1", shape="cds"];
  l2a_boresight_cti [label="L2a_Astrometric charge xfer inefficiency 1..1", shape="cds"];
  l2a_boresight_dnb [label="L2a_Astrometric CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
  l2a_boresight_mbpm [label="L2a_Astrometric master bad pixel map 1..1", shape="cds"];
  l2a_boresight_ff [label="L2a_Astrometric flat fields 1..1", shape="cds"];
  l2a_boresight_emg [label="L2a_Astrometric EM gain 1..1", shape="cds"];
  l2a_boresight_kgain [label="L2_Astrometric Kgain 1..1", shape="cds"];
  l2a_boresight_log [label="L2a_Astrometric log 1..1", shape="ellipse"];
  
  l2b_boresight_prod [label="L2b_Astrometric products 1..1", shape="rectangle"];
  l2b_boresight_man [label="L2b_Astrometric manifest 1..1", shape="ellipse"];
  l2b_boresight_odir [label="L2b_Astrometric output path 1..1", shape="ellipse"];
  l2b_boresight_rec [label="L2b_Astrometric recipe 1..1", shape="cds"];
  l2b_boresight_excicrf [label="L2b_Astrometric EXCAM ICRF location 1..1", shape="cds"];
  l2b_boresight_excfovps [label="L2b_Astrometric EXCAM FOV pixel scale 1..1", shape="cds"];

  l2b_boresight_distm [label="L2b_Astrometric distortion map 1..1", shape="cds"];
  l2b_boresight_log [label="L2b_Astrometric log 1..1", shape="ellipse"];

  boresight_prod [label="Astrometric products 1..1", shape="rectangle"];
  boresight_log [label="Astrometric log 1..1", shape="ellipse"];
  boresight_man [label="Astrometric manifest 1..1", shape="ellipse"];
  
  l1_boresight_prod -> trans_boresight_l1_l2a [style="dashed"];
  l1_boresight_man -> trans_boresight_l1_l2a;
  l1_boresight_odir -> trans_boresight_l1_l2a;
  l1_boresight_rec -> trans_boresight_l1_l2a;
  l1_boresight_nllut -> trans_boresight_l1_l2a;

  trans_boresight_l1_l2a -> l2a_boresight_prod [style="dashed"];
  trans_boresight_l1_l2a -> l2a_boresight_man;  
  trans_boresight_l1_l2a -> l2a_boresight_log [style="dashed"];  

  l2a_boresight_prod -> trans_boresight_l2a_l2b [style="dashed"];
  l2a_boresight_kgain -> trans_boresight_l2a_l2b;
  l2a_boresight_odir -> trans_boresight_l2a_l2b;
  l2a_boresight_rec -> trans_boresight_l2a_l2b;
  l2a_boresight_cti -> trans_boresight_l2a_l2b;
  l2a_boresight_dnb -> trans_boresight_l2a_l2b;
  l2a_boresight_mbpm -> trans_boresight_l2a_l2b;
  l2a_boresight_ff -> trans_boresight_l2a_l2b;
  l2a_boresight_emg -> trans_boresight_l2a_l2b;
  l2a_boresight_man -> trans_boresight_l2a_l2b;
  
  trans_boresight_l2a_l2b -> l2b_boresight_prod [style="dashed"];
  trans_boresight_l2a_l2b -> l2b_boresight_log [style="dashed"];
  trans_boresight_l2a_l2b -> l2b_boresight_man;

  l2b_boresight_prod -> trans_boresight_l2b_aboresight [style="dashed"];
  l2b_boresight_man -> trans_boresight_l2b_aboresight;
  l2b_boresight_odir -> trans_boresight_l2b_aboresight;
  l2b_boresight_rec -> trans_boresight_l2b_aboresight;
  l2b_boresight_excicrf -> trans_boresight_l2b_aboresight;
  l2b_boresight_excfovps -> trans_boresight_l2b_aboresight;
  l2b_boresight_distm -> trans_boresight_l2b_aboresight;
  trans_boresight_l2b_aboresight -> boresight_prod [style="dashed"];
  trans_boresight_l2b_aboresight -> boresight_man;
  trans_boresight_l2b_aboresight -> boresight_log [style="dashed"];  

}
