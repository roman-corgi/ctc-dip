digraph Astrometric {
graph [splines="ortho", rankdir=LR];
trans_cal_boresight_l1_l2a [label="Astrometric\nTransmutation\nL1 to L2a basic", shape="circle", runname="l1.transmutation_cal_boresight", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
trans_cal_boresight_l2a_l2b [label="Astrometric\nTransmutation\nL2a to L2b", shape="circle", runname="l2a.transmutation_cal_boresight", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
trans_cal_boresight_l2b_aboresight [label="Astrometric\nTransmutation\nL2b to CoreAstrometric", shape="circle", runname="l2b.transmutation_cal_boresight", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
l1_cal_boresight_prod [label="L1_Astrometric products 1..b", shape="rectangle"];
l1_cal_boresight_man [label="L1_Astrometric manifest 1..1", shape="ellipse"];
l1_cal_boresight_odir [label="L1_Astrometric output path 1..1", shape="ellipse"];
l1_cal_boresight_rec [label="L1_Astrometric recipe 1..1", shape="cds"];
l1_cal_boresight_nllut [label="L1_Astrometric non-linear LUT 1..1", shape="cds"];
l2a_cal_boresight_prod [label="L2a_Astrometric products 1..b", shape="rectangle"];
l2a_cal_boresight_man [label="L2a_Astrometric manifest 1..1", shape="ellipse", valname="l1.transmutation_cal_boresight.product.manifest", valtype="dip.base.Manifest"];
l2a_cal_boresight_odir [label="L2a_Astrometric output path 1..1", shape="ellipse"];
l2a_cal_boresight_rec [label="L2a_Astrometric recipe 1..1", shape="cds"];
l2a_cal_boresight_cti [label="L2a_Astrometric charge xfer inefficiency 1..1", shape="cds"];
l2a_cal_boresight_dnb [label="L2a_Astrometric CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
l2a_cal_boresight_mbpm [label="L2a_Astrometric master bad pixel map 1..1", shape="cds"];
l2a_cal_boresight_ff [label="L2a_Astrometric flat fields 1..1", shape="cds"];
l2a_cal_boresight_emg [label="L2a_Astrometric EM gain 1..1", shape="cds"];
l2a_cal_boresight_kgain [label="L2_Astrometric Kgain 1..1", shape="cds"];
l2a_cal_boresight_log [label="L2a_Astrometric log 1..1", shape="ellipse"];
l2b_cal_boresight_prod [label="L2b_Astrometric products 1..1", shape="rectangle"];
l2b_cal_boresight_man [label="L2b_Astrometric manifest 1..1", shape="ellipse", valname="l2a.transmutation_cal_boresight.product.manifest", valtype="dip.base.Manifest"];
l2b_cal_boresight_odir [label="L2b_Astrometric output path 1..1", shape="ellipse"];
l2b_cal_boresight_rec [label="L2b_Astrometric recipe 1..1", shape="cds"];
l2b_cal_boresight_excicrf [label="L2b_Astrometric EXCAM ICRF location 1..1", shape="cds"];
l2b_cal_boresight_excfovps [label="L2b_Astrometric EXCAM FOV pixel scale 1..1", shape="cds"];
l2b_cal_boresight_distm [label="L2b_Astrometric distortion map 1..1", shape="cds"];
l2b_cal_boresight_log [label="L2b_Astrometric log 1..1", shape="ellipse"];
cal_boresight_prod [label="Astrometric products 1..1", shape="rectangle"];
cal_boresight_log [label="Astrometric log 1..1", shape="ellipse"];
cal_boresight_man [label="Astrometric manifest 1..1", shape="ellipse"];
l1_cal_boresight_prod -> trans_cal_boresight_l1_l2a [style="dashed"];
l1_cal_boresight_man -> trans_cal_boresight_l1_l2a;
l1_cal_boresight_odir -> trans_cal_boresight_l1_l2a;
l1_cal_boresight_rec -> trans_cal_boresight_l1_l2a;
l1_cal_boresight_nllut -> trans_cal_boresight_l1_l2a;
trans_cal_boresight_l1_l2a -> l2a_cal_boresight_prod [style="dashed"];
trans_cal_boresight_l1_l2a -> l2a_cal_boresight_man;
trans_cal_boresight_l1_l2a -> l2a_cal_boresight_log [style="dashed"];
l2a_cal_boresight_prod -> trans_cal_boresight_l2a_l2b [style="dashed"];
l2a_cal_boresight_kgain -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_odir -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_rec -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_cti -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_dnb -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_mbpm -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_ff -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_emg -> trans_cal_boresight_l2a_l2b;
l2a_cal_boresight_man -> trans_cal_boresight_l2a_l2b;
trans_cal_boresight_l2a_l2b -> l2b_cal_boresight_prod [style="dashed"];
trans_cal_boresight_l2a_l2b -> l2b_cal_boresight_log [style="dashed"];
trans_cal_boresight_l2a_l2b -> l2b_cal_boresight_man;
l2b_cal_boresight_prod -> trans_cal_boresight_l2b_aboresight [style="dashed"];
l2b_cal_boresight_man -> trans_cal_boresight_l2b_aboresight;
l2b_cal_boresight_odir -> trans_cal_boresight_l2b_aboresight;
l2b_cal_boresight_rec -> trans_cal_boresight_l2b_aboresight;
l2b_cal_boresight_excicrf -> trans_cal_boresight_l2b_aboresight;
l2b_cal_boresight_excfovps -> trans_cal_boresight_l2b_aboresight;
l2b_cal_boresight_distm -> trans_cal_boresight_l2b_aboresight;
trans_cal_boresight_l2b_aboresight -> cal_boresight_prod [style="dashed"];
trans_cal_boresight_l2b_aboresight -> cal_boresight_man;
trans_cal_boresight_l2b_aboresight -> cal_boresight_log [style="dashed"];
}
