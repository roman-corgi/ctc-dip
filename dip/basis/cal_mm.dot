digraph MuellerMatrixCalibrations {
graph [splines="ortho", rankdir=LR];
trans_cal_mm_l1_l2a [label="MuellerMatrix\nTransmutation\nL1 to L2a basic", shape="circle", runname="l1.transmutation_cal_mm", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
l1_cal_mm_prod [label="L1_MuellerMatrix products 1..b", shape="rectangle"];
l1_cal_mm_man [label="L1_MuellerMatrix manifest 1..1", shape="ellipse"];
l1_cal_mm_odir [label="L1_MuellerMatrix output path 1..1", shape="ellipse"];
l1_cal_mm_rec [label="L1_MuellerMatrix recipe 1..1", shape="cds"];
cal_mm_prod [label="MuellerMatrix products 1..1", shape="rectangle"];
cal_mm_log [label="MuellerMatrix log 1..1", shape="ellipse"];
cal_mm_man [label="MuellerMatrix product manifest 1..1", shape="ellipse", shape="ellipse", valname="l1.transmutation_cal_mm.product.manifest", valtype="dip.base.Manifest"];
cal_mm_src [label="MuellerMatrix source manifest 1..1", shape="ellipse", valname="l1.transmutation_cal_mm.source.manifest", valtype="dip.base.Manifest"];
l1_cal_mm_prod -> trans_cal_mm_l1_l2a [style="dashed"];
l1_cal_mm_man -> trans_cal_mm_l1_l2a;
l1_cal_mm_odir -> trans_cal_mm_l1_l2a;
l1_cal_mm_rec -> trans_cal_mm_l1_l2a;
trans_cal_mm_l1_l2a -> cal_mm_prod [style="dashed"];
trans_cal_mm_l1_l2a -> cal_mm_man;
trans_cal_mm_l1_l2a -> cal_mm_src;
trans_cal_mm_l1_l2a -> cal_mm_log [style="dashed"];
}
