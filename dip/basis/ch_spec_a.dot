digraph AbstractDesign
{
  graph [splines="ortho", rankdir=LR];

  trans_spec_a_l1_l2a [label="spec_a Transmutation\nL1 to L2a", shape="circle"];
  l2a_spec_a_demux [label="spec_a l2a Demux\nExposure" shape="circle"];
  trans_spec_a_l2a_l2b [label="spec_a Transmutation\nL2a to L2b", shape="circle"];
  l2b_spec_a_mux [label="spec_a l2b Mux\nExposure", shape="circle"];
  trans_spec_a_l2b_l3 [label="spec_a Transmutation\nL2b to L3", shape="circle"];
  trans_spec_a_l3_l4 [label="spec_a Transmutation\nL3 to L4", shape="circle"];
  trans_spec_a_l4_tda [label="spec_a Transmutation\nL4 to TDA", shape="circle"];
        
  l1_spec_a_prod [label="L1_spec_a products 1..b", shape="rectangle"];
  l1_spec_a_man [label="L1_spec_a manifest 1..1", shape="ellipse"];
  l1_spec_a_odir [label="L1_spec_a output path 1..1", shape="ellipse"];
  l1_spec_a_rec [label="L1_spec_a recipe 1..1", shape="cds"];
  l1_spec_a_nln [label="L1_spec_a non-linear & Kgain 1..1", shape="cds"];

  l2a_spec_a_prod [label="L2a_spec_a products 1..b", shape="rectangle"];
  l2a_spec_a_man [label="L2a_spec_a manifest 1..1", shape="ellipse"];
  l2a_spec_a_odir [label="L2a_spec_a output path 1..1", shape="ellipse"];
  l2a_spec_a_rec [label="L2a_spec_a recipe 1..1", shape="cds"];
  l2a_spec_a_cti [label="L2a_spec_a charge xfer inefficiency 1..1", shape="cds"];
  l2a_spec_a_dnb [label="L2a_spec_a detector noise background 1..1", shape="cds"];
  l2a_spec_a_mbpm [label="L2a_spec_a master bad pixel map 1..1", shape="cds"];
  l2a_spec_a_emg [label="L2a_spec_a EM gain 1..1", shape="cds"];
  l2a_spec_a_log [label="L2a log_spec_a 1..1", shape="ellipse"];
  l2a_spec_a_man_demux [label="L2a_spec_a(E) manifest 1..1", shape="ellipse"];
  
  l2b_spec_a_prod [label="L2b_spec_a products 1..1", shape="rectangle"];
  l2b_spec_a_man [label="L2b_spec_a manifest 1..1", shape="ellipse"];
  l2b_spec_a_odir [label="L2b_spec_a output path 1..1", shape="ellipse"];
  l2b_spec_a_rec [label="L2b_spec_a recipe 1..1", shape="cds"];
  l2b_spec_a_excicrf [label="L2b_spec_a EXCAM ICRF location 1..1", shape="cds"];
  l2b_spec_a_excfovps [label="L2b_spec_a EXCAM FOV pixel scale 1..1", shape="cds"];
  l2b_spec_a_cfamfo [label="L2b_spec_a CFAM filter offsets 1..1", shape="cds"];
  l2b_spec_a_man_demux [label="L2b_spec_a(E) manifest 1..1", shape="ellipse"];
  l2b_spec_a_log [label="L2b_spec_a log 1..1", shape="ellipse"];

  l3_spec_a_prod [label="L3_spec_a products 1..1", shape="rectangle"];
  l3_spec_a_odir [label="L3_spec_a output path 1..1", shape="ellipse"];
  l3_spec_a_man [label="L3_spec_a manifest 1..1", shape="ellipse"];
  l3_spec_a_rec [label="L3_spec_a recipe 1..1", shape="cds"];
  l3_spec_a_dispm [label="L3_spec_a dispersion model 1..1", shape="cds"];
  l3_spec_a_wavem [label="L3_spec_a wavelength map 1..1", shape="cds"];
  l3_spec_a_log [label="L3_spec_a log 1..1", shape="ellipse"];

  l4_spec_a_prod [label="L4_spec_a products 1..1", shape="rectangle"];
  l4_spec_a_odir [label="L4_spec_a output path 1..1", shape="ellipse"];
  l4_spec_a_log [label="L4_spec_a log 1..1", shape="ellipse"];
  l4_spec_a_man [label="L4_spec_a manifest 1..1", shape="ellipse"];
  l4_spec_a_rec [label="L4_spec_a recipe 1..1", shape="cds"];
  l4_spec_a_afcal [label="L4_spec_a absolute flux calibrations 1..1", shape="cds"];
  l4_spec_a_ndfilt [label="L4_spec_a ND filter 1..1", shape="cds"];
  l4_spec_a_stmap [label="L4_spec_a slit transmission map 1..1", shape="cds"];
  l4_spec_a_tspi [label="L4_spec_a target star prism image 1..1", shape="cds"];
  l4_spec_a_rspi [label="L4_spec_a reference star prism image 1..1", shape="cds"];
  l4_spec_a_lsf [label="L4_spec_a line spread function 1..1", shape="cds"];

  l1_spec_a_prod -> trans_spec_a_l1_l2a;
  l1_spec_a_man -> trans_spec_a_l1_l2a;
  l1_spec_a_odir -> trans_spec_a_l1_l2a;
  l1_spec_a_rec -> trans_spec_a_l1_l2a;
  l1_spec_a_nln -> trans_spec_a_l1_l2a;

  trans_spec_a_l1_l2a -> l2a_spec_a_prod;
  trans_spec_a_l1_l2a -> l2a_spec_a_man;  
  trans_spec_a_l1_l2a -> l2a_spec_a_log;  

  l2a_spec_a_prod -> trans_spec_a_l2a_l2b;
  l2a_spec_a_odir -> trans_spec_a_l2a_l2b;
  l2a_spec_a_rec -> trans_spec_a_l2a_l2b;
  l2a_spec_a_cti -> trans_spec_a_l2a_l2b;
  l2a_spec_a_dnb -> trans_spec_a_l2a_l2b;
  l2a_spec_a_mbpm -> trans_spec_a_l2a_l2b;
  l2a_spec_a_emg -> trans_spec_a_l2a_l2b;

  trans_spec_a_l2a_l2b -> l2b_spec_a_prod;
  trans_spec_a_l2a_l2b -> l2b_spec_a_man_demux;
  trans_spec_a_l2a_l2b -> l2b_spec_a_log;

  l2a_spec_a_man -> l2a_spec_a_demux;
  l2a_spec_a_demux -> l2a_spec_a_man_demux;
  l2a_spec_a_man_demux -> trans_spec_a_l2a_l2b;
  
  l2b_spec_a_man_demux -> l2b_spec_a_mux;
  l2b_spec_a_mux -> l2b_spec_a_man;
  
  l2b_spec_a_prod -> trans_spec_a_l2b_l3;
  l2b_spec_a_man -> trans_spec_a_l2b_l3;
  l2b_spec_a_odir -> trans_spec_a_l2b_l3;
  l2b_spec_a_rec -> trans_spec_a_l2b_l3;
  l2b_spec_a_excicrf -> trans_spec_a_l2b_l3;
  l2b_spec_a_excfovps -> trans_spec_a_l2b_l3;
  l2b_spec_a_cfamfo -> trans_spec_a_l2b_l3;

  trans_spec_a_l2b_l3 -> l3_spec_a_prod;
  trans_spec_a_l2b_l3 -> l3_spec_a_man;  
  trans_spec_a_l2b_l3 -> l3_spec_a_log;  

  l3_spec_a_prod -> trans_spec_a_l3_l4;
  l3_spec_a_man -> trans_spec_a_l3_l4;
  l3_spec_a_odir -> trans_spec_a_l3_l4;
  l3_spec_a_rec -> trans_spec_a_l3_l4;
  l3_spec_a_dispm -> trans_spec_a_l3_l4;
  l3_spec_a_wavem -> trans_spec_a_l3_l4;
  trans_spec_a_l3_l4 -> l4_spec_a_prod;
  trans_spec_a_l3_l4 -> l4_spec_a_log;
  trans_spec_a_l3_l4 -> l4_spec_a_man;

  l4_spec_a_prod -> trans_spec_a_l4_tda;
  l4_spec_a_man -> trans_spec_a_l4_tda;
  l4_spec_a_odir -> trans_spec_a_l4_tda;
  l4_spec_a_rec -> trans_spec_a_l4_tda;
  l4_spec_a_afcal -> trans_spec_a_l4_tda;
  l4_spec_a_ndfilt -> trans_spec_a_l4_tda;
  l4_spec_a_stmap -> trans_spec_a_l4_tda;
  l4_spec_a_tspi -> trans_spec_a_l4_tda;
  l4_spec_a_rspi -> trans_spec_a_l4_tda;
  l4_spec_a_lsf -> trans_spec_a_l4_tda;
  trans_spec_a_l4_tda -> tda_spec_a_prod;
  trans_spec_a_l4_tda -> tda_spec_a_log;
}
