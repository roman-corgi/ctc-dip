/* why separate channels and how are they tied back together
*
* The magic happens from clerks.dot. It contains the same clerks but with dawgie
* information tied to the nodes. Since they are all named the same among these
* channlized files and clerks.dot, the dip.basis.transmute distills then
* condenses them into a hidden monolithic concept if they have dawgie
* information associated with them. That is the real magic.
*/
digraph Clerks
{
  graph [splines="ortho", rankdir=LR];

  alarm_cal [label="User requested update", shape="none"];
  alarm_cnf [label="User requested update", shape="none"];
  alarm_rec [label="User requested update", shape="none"];
  
  calib [label="Calibration", shape="circle"];
  config [label="Configuration", shape="circle"];
  recipe [label="Recipe", shape="circle"];

  l1_wfov_nc_odir [label="Output path for L1_wfov_nc 1..1", shape="ellipse",
                 valname="clerk.configuration.l1_wfov_nc.outdir",
                 valtype="dip.base.Configuration"];
  l1_wfov_nc_rec [label="recipe L1_wfov_nc 1..1", shape="cds",
                valname="clerk.recipe.l1_wfov_nc.recipe",
                valtype="dip.base.Recipe"];
  l1_wfov_nc_nllut [label="non linear calibration 1..1", shape="cds",
                     valname="clerk.calibration.l1_wfov_nc.nonlin",
                     valtype="dip.base.Calibration"];
  l2a_wfov_nc_odir [label="Output path for L2a_wfov_nc 1..1", shape="ellipse",
                 valname="clerk.configuration.l2a_wfov_nc.outdir",
                 valtype="dip.base.Configuration"];
  l2a_wfov_nc_rec [label="recipe L2a_wfov_nc 1..1", shape="cds",
                 valname="clerk.recipe.l2a_wfov_nc.recipe",
                 valtype="dip.base.Recipe"];
  l2a_wfov_nc_mbpm [label="wfov_nc bad pixel map 1..1", shape="cds",
                valname="clerk.calibration.l2a_wfov_nc.bad_pix_map",
                valtype="dip.base.Calibration"];
  l2a_wfov_nc_dnb  [label="wfov_nc dark (CIC/FPN/dark current) 1..1", shape="cds",
                  valname="clerk.calibration.l2a_wfov_nc.darks",
                  valtype="dip.base.Calibration"];
  l2a_wfov_nc_cti  [label="wfov_nc charge transfer efficiency 1..1", shape="cds",
                valname="clerk.calibration.l2a_wfov_nc.charge_xfer_eff",
                valtype="dip.base.Calibration"];
  l2a_wfov_nc_ff  [label="wfov_nc flat field 1..1", shape="cds",
                valname="clerk.calibration.l2a_wfov_nc.flat_field",
                valtype="dip.base.Calibration"];
  l2a_wfov_nc_kgain  [label="wfov_nc k-gain 1..1", shape="cds",
                valname="clerk.calibration.l2a_wfov_nc.k_gain",
                valtype="dip.base.Calibration"];
  l2a_wfov_nc_emg [label="wfov_nc EM gain 1..1", shape="cds",
                valname="clerk.calibration.l2a_wfov_nc.em_gain",
                valtype="dip.base.Calibration"];
  l2b_wfov_nc_odir [label="Output path for L2b_wfov_nc 1..1", shape="ellipse",
                 valname="clerk.configuration.l2b_wfov_nc.outdir",
                 valtype="dip.base.Configuration"];
  l2b_wfov_nc_rec [label="recipe L2b_wfov_nc 1..1", shape="cds",
                 valname="clerk.recipe.l2b_wfov_nc.recipe",
                 valtype="dip.base.Recipe"];
  l2b_wfov_nc_distm [label="wfov_nc distortion map 1..1", shape="cds",
                 valname="clerk.calibration.l2b_wfov_nc.distortion_map",
                 valtype="dip.base.Calibration"];
  l2b_wfov_nc_excicrf [label="wfov_nc EXCAM ICRF location 1..1", shape="cds",
                 valname="clerk.calibration.l2b_wfov_nc.excam_icrf_location",
                 valtype="dip.base.Calibration"];
  l2b_wfov_nc_excfovps [label="wfov_nc ECAM FOV pixel scale 1..1", shape="cds",
                 valname="clerk.calibration.l2b_wfov_nc.excam_fov_pixel_scale",
                 valtype="dip.base.Calibration"];
  l3_wfov_nc_odir [label="Output path for L3_wfov_nc 1..1", shape="ellipse",
                 valname="clerk.configuration.l3_wfov_nc.outdir",
                 valtype="dip.base.Configuration"];
  l3_wfov_nc_rec [label="recipe L3_wfov_nc 1..1", shape="cds",
                 valname="clerk.recipe.l3_wfov_nc.recipe",
                 valtype="dip.base.Recipe"];
  l3_wfov_nc_ast [label="wfov_nc astrometry 1..1", shape="cds",
                 valname="clerk.calibration.l3_wfov_nc.astrometry",
                 valtype="dip.base.Calibration"];
  l3_wfov_nc_ndf [label="wfov_nc astrometry 1..1", shape="cds",
                 valname="clerk.calibration.l3_wfov_nc.ndfilter",
                 valtype="dip.base.Calibration"];
  l4_wfov_nc_odir [label="Output path for L4_wfov_nc 1..1", shape="ellipse",
                 valname="clerk.configuration.l4_wfov_nc.outdir",
                 valtype="dip.base.Configuration"];
  l4_wfov_nc_rec [label="recipe L4_wfov_nc 1..1", shape="cds",
                 valname="clerk.recipe.l4_wfov_nc.recipe",
                 valtype="dip.base.Recipe"];
  l4_wfov_nc_afcal [label="wfov_nc absolute flux 1..1", shape="cds",
                 valname="clerk.calibration.l4_wfov_nc.absolute_flux",
                 valtype="dip.base.Calibration"];
  l4_wfov_nc_ctcal [label="wfov_nc core throughput 1..1", shape="cds",
                 valname="clerk.calibration.l4_wfov_nc.core_thruput",
                 valtype="dip.base.Calibration"];
  l4_wfov_nc_ndfilt [label="wfov_nc ND filter 1..1", shape="cds",
                 valname="clerk.calibration.l4_wfov_nc.nd_filter",
                 valtype="dip.base.Calibration"];

  alarm_cal -> calib [style="dashed"];
  alarm_cnf -> config [style="dashed"];
  alarm_rec -> recipe [style="dashed"];

  calib -> l1_wfov_nc_nllut;
  calib -> l2a_wfov_nc_mbpm;
  calib -> l2a_wfov_nc_dnb;
  calib -> l2a_wfov_nc_cti;
  calib -> l2a_wfov_nc_ff;
  calib -> l2a_wfov_nc_kgain;
  calib -> l2a_wfov_nc_emg;
  calib -> l2b_wfov_nc_distm;
  calib -> l2b_wfov_nc_excicrf;
  calib -> l2b_wfov_nc_excfovps;
  calib -> l3_wfov_nc_ast;
  calib -> l3_wfov_nc_ndf;
  calib -> l4_wfov_nc_afcal;
  calib -> l4_wfov_nc_ctcal;
  calib -> l4_wfov_nc_ndfilt;
  config -> l1_wfov_nc_odir;
  config -> l2a_wfov_nc_odir;
  config -> l2b_wfov_nc_odir;
  config -> l3_wfov_nc_odir;
  config -> l4_wfov_nc_odir;
  recipe -> l1_wfov_nc_rec;
  recipe -> l2a_wfov_nc_rec;
  recipe -> l2b_wfov_nc_rec;
  recipe -> l3_wfov_nc_rec;
  recipe -> l4_wfov_nc_rec;
}
