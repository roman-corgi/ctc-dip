l2b_cal_absflux_src [label="L2b_AbsFlux source manifest 1..1", shape="ellipse", valname="l2a.transmutation_cal_absflux.source.manifest", valtype="dip.base.Manifest"];
l2b_cal_absflux_odir [label="L2b_AbsFlux output path 1..1", shape="ellipse"];
l2b_cal_absflux_rec [label="L2b_AbsFlux recipe 1..1", shape="cds"];
l2b_cal_absflux_excicrf [label="L2b_AbsFlux EXCAM ICRF location 1..1", shape="cds"];
l2b_cal_absflux_excfovps [label="L2b_AbsFlux EXCAM FOV pixel scale 1..1", shape="cds"];
