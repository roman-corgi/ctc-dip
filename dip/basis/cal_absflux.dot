l2a_cal_absflux_cti [label="L2a_AbsFlux charge xfer inefficiency 1..1", shape="cds"];
l2a_cal_absflux_dnb [label="L2a_AbsFlux CIC/Dark Current/FPN\n or master dark 1..1", shape="cds"];
l2a_cal_absflux_mbpm [label="L2a_AbsFlux master bad pixel map 1..1", shape="cds"];
l2a_cal_absflux_ff [label="L2a_AbsFlux flat fields 1..1", shape="cds"];
l2a_cal_absflux_emg [label="L2a_AbsFlux EM gain 1..1", shape="cds"];
