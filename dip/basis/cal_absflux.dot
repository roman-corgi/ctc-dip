l2b_cal_absflux_prod -> trans_cal_absflux_l2b_ctp [style="dashed"];
l2b_cal_absflux_man -> trans_cal_absflux_l2b_ctp;
l2b_cal_absflux_odir -> trans_cal_absflux_l2b_ctp;
