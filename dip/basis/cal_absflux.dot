digraph AbsoluteFluxCalibration {
graph [splines="ortho", rankdir=LR];
trans_cal_absflux_l1_l2a [label="AbsFlux\nTransmutation\nL1 to L2a basic", shape="circle", runname="l1.transmutation_cal_absflux", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
trans_cal_absflux_l2a_l2b [label="AbsFlux\nTransmutation\nL2a to L2b", shape="circle", runname="l2a.transmutation_cal_absflux", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
trans_cal_absflux_l2b_ctp [label="AbsFlux\nTransmutation\nL2b to AbsFlux", shape="circle", runname="l2b.transmutation_cal_absflux", runtype="dawgie.Algorithm", fsmtype="dip.base.Runner"];
l1_cal_absflux_prod [label="L1_AbsFlux products 1..b", shape="rectangle"];
l1_cal_absflux_man [label="L1_AbsFlux manifest 1..1", shape="ellipse"];
