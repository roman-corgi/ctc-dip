/* why separate channels and how are they tied back together
*
* The magic happens from clerks.dot. It contains the same clerks but with dawgie
* information tied to the nodes. Since they are all named the same among these
* channlized files and clerks.dot, the dip.basis.transmute distills then
* condenses them into a hidden monolithic concept if they have dawgie
* information associated with them. That is the real magic.
*/
digraph BoresightClerks
{
  graph [splines="ortho", rankdir=LR];

  alarm_cal [label="User requested update", shape="none"];
  alarm_cnf [label="User requested update", shape="none"];
  alarm_rec [label="User requested update", shape="none"];
  
  calib [label="Calibration", shape="circle"];
  config [label="Configuration", shape="circle"];
  recipe [label="Recipe", shape="circle"];

  l1_cal_boresight_odir [label="Output path for L1_cal_boresight 1..1", shape="ellipse",
                         valname="clerk.configuration.l1_cal_boresight.outdir",
                         valtype="dip.base.Configuration"];
  l1_cal_boresight_rec [label="recipe L1_eng_a 1..1", shape="cds",
                        valname="clerk.recipe.l1_cal_boresight.recipe",
                        valtype="dip.base.Recipe"];
  l1_cal_boresight_nllut [label="non linear calibration 1..1", shape="cds",
                          valname="clerk.calibration.l1_cal_boresight.nonlin",
                          valtype="dip.base.Calibration"];

  l2a_cal_boresight_mbpm [label="cal_boresight bad pixel map 1..1", shape="cds",
                          valname="clerk.calibration.l2a_cal_boresight.bad_pix_map",
                          valtype="dip.base.Calibration"];
  l2a_cal_boresight_dnb  [label="cal_boresight dark (CIC/FPN/dark current) 1..1", shape="cds",
                          valname="clerk.calibration.l2a_cal_boresight.darks",
                          valtype="dip.base.Calibration"];
  l2a_cal_boresight_cti  [label="cal_boresight charge transfer efficiency 1..1", shape="cds",
                          valname="clerk.calibration.l2a_cal_boresight.charge_xfer_eff",
                          valtype="dip.base.Calibration"];
  l2a_cal_boresight_ff  [label="cal_boresight flat field 1..1", shape="cds",
                         valname="clerk.calibration.l2a_cal_boresight.flat_field",
                         valtype="dip.base.Calibration"];
  l2a_cal_boresight_kgain  [label="cal_boresight k-gain 1..1", shape="cds",
                            valname="clerk.calibration.l2a_cal_boresight.k_gain",
                            valtype="dip.base.Calibration"];
  l2a_cal_boresight_emg [label="cal_boresight EM gain 1..1", shape="cds",
                         valname="clerk.calibration.l2a_cal_boresight.em_gain",
                         valtype="dip.base.Calibration"];

  alarm_cal -> calib [style="dashed"];
  alarm_cnf -> config [style="dashed"];
  alarm_rec -> recipe [style="dashed"];

  calib -> l1_cal_boresight_nllut;
  calib -> l2a_cal_boresight_mbpm;
  calib -> l2a_cal_boresight_dnb;
  calib -> l2a_cal_boresight_cti;
  calib -> l2a_cal_boresight_ff;
  calib -> l2a_cal_boresight_kgain;
  calib -> l2a_cal_boresight_emg;
  config -> l1_cal_boresight_odir;
  recipe -> l1_cal_boresight_rec;
}
