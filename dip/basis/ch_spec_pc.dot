  l2a_spec_pc_rec [label="L2a_spec_pc recipe 1..1", shape="cds"];
  l2a_spec_pc_cti [label="L2a_spec_pc charge xfer inefficiency 1..1", shape="cds"];
  l2a_spec_pc_dnb [label="L2a_spec_pc detector noise background 1..1", shape="cds"];
  l2a_spec_pc_mbpm [label="L2a_spec_pc master bad pixel map 1..1", shape="cds"];
  l2a_spec_pc_emg [label="L2a_spec_pc EM gain 1..1", shape="cds"];
  l2a_spec_pc_log [label="L2a log_spec_pc 1..1", shape="ellipse"];
  l2a_spec_pc_man_demux [label="L2a_spec_pc(E) manifest 1..1", shape="ellipse"];
  
  l2b_spec_pc_prod [label="L2b_spec_pc products 1..1", shape="rectangle"];
  l2b_spec_pc_man [label="L2b_spec_pc manifest 1..1", shape="ellipse"];
  l2b_spec_pc_odir [label="L2b_spec_pc output path 1..1", shape="ellipse"];
  l2b_spec_pc_rec [label="L2b_spec_pc recipe 1..1", shape="cds"];
  l2b_spec_pc_excicrf [label="L2b_spec_pc EXCAM ICRF location 1..1", shape="cds"];
  l2b_spec_pc_excfovps [label="L2b_spec_pc EXCAM FOV pixel scale 1..1", shape="cds"];
  l2b_spec_pc_cfamfo [label="L2b_spec_pc CFAM filter offsets 1..1", shape="cds"];
  l2b_spec_pc_man_demux [label="L2b_spec_pc(E) manifest 1..1", shape="ellipse"];
  l2b_spec_pc_log [label="L2b_spec_pc log 1..1", shape="ellipse"];

  l3_spec_pc_prod [label="L3_spec_pc products 1..1", shape="rectangle"];
