digraph AbstractDesign
{
  graph [splines="ortho", rankdir=LR];

  trans_spec_pc_l1_l2a [label="spec_pc Transmutation\nL1 to L2a", shape="circle"];
  l2a_spec_pc_demux [label="spec_pc l2a Demux\nExposure" shape="circle"];
  trans_spec_pc_l2a_l2b [label="spec_pc Transmutation\nL2a to L2b", shape="circle"];
  l2b_spec_pc_mux [label="spec_pc l2b Mux\nExposure", shape="circle"];
  trans_spec_pc_l2b_l3 [label="spec_pc Transmutation\nL2b to L3", shape="circle"];
  trans_spec_pc_l3_l4 [label="spec_pc Transmutation\nL3 to L4", shape="circle"];
  trans_spec_pc_l4_tda [label="spec_pc Transmutation\nL4 to TDA", shape="circle"];
        
  l1_spec_pc_prod [label="L1_spec_pc products 1..b", shape="rectangle"];
  l1_spec_pc_man [label="L1_spec_pc manifest 1..1", shape="ellipse"];
  l1_spec_pc_odir [label="L1_spec_pc output path 1..1", shape="ellipse"];
  l1_spec_pc_rec [label="L1_spec_pc recipe 1..1", shape="cds"];
  l1_spec_pc_nln [label="L1_spec_pc non-linear & Kgain 1..1", shape="cds"];

  l2a_spec_pc_prod [label="L2a_spec_pc products 1..b", shape="rectangle"];
  l2a_spec_pc_man [label="L2a_spec_pc manifest 1..1", shape="ellipse"];
