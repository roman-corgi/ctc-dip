  trans_spec_pc_l2b_l3 -> l3_spec_pc_prod;
  trans_spec_pc_l2b_l3 -> l3_spec_pc_man;  
  trans_spec_pc_l2b_l3 -> l3_spec_pc_log;  

  l3_spec_pc_prod -> trans_spec_pc_l3_l4;
  l3_spec_pc_man -> trans_spec_pc_l3_l4;
  l3_spec_pc_odir -> trans_spec_pc_l3_l4;
  l3_spec_pc_rec -> trans_spec_pc_l3_l4;
  l3_spec_pc_dispm -> trans_spec_pc_l3_l4;
  l3_spec_pc_wavem -> trans_spec_pc_l3_l4;
  trans_spec_pc_l3_l4 -> l4_spec_pc_prod;
  trans_spec_pc_l3_l4 -> l4_spec_pc_log;
  trans_spec_pc_l3_l4 -> l4_spec_pc_man;

  l4_spec_pc_prod -> trans_spec_pc_l4_tda;
  l4_spec_pc_man -> trans_spec_pc_l4_tda;
  l4_spec_pc_odir -> trans_spec_pc_l4_tda;
  l4_spec_pc_rec -> trans_spec_pc_l4_tda;
  l4_spec_pc_afcal -> trans_spec_pc_l4_tda;
  l4_spec_pc_ndfilt -> trans_spec_pc_l4_tda;
  l4_spec_pc_stmap -> trans_spec_pc_l4_tda;
  l4_spec_pc_tspi -> trans_spec_pc_l4_tda;
  l4_spec_pc_rspi -> trans_spec_pc_l4_tda;
  l4_spec_pc_lsf -> trans_spec_pc_l4_tda;
  trans_spec_pc_l4_tda -> tda_spec_pc_prod;
  trans_spec_pc_l4_tda -> tda_spec_pc_log;
}
