  l3_spec_pc_wavem [label="L3_spec_pc wavelength map 1..1", shape="cds"];
  l3_spec_pc_log [label="L3_spec_pc log 1..1", shape="ellipse"];

  l4_spec_pc_prod [label="L4_spec_pc products 1..1", shape="rectangle"];
  l4_spec_pc_odir [label="L4_spec_pc output path 1..1", shape="ellipse"];
  l4_spec_pc_log [label="L4_spec_pc log 1..1", shape="ellipse"];
  l4_spec_pc_man [label="L4_spec_pc manifest 1..1", shape="ellipse"];
  l4_spec_pc_rec [label="L4_spec_pc recipe 1..1", shape="cds"];
  l4_spec_pc_afcal [label="L4_spec_pc absolute flux calibrations 1..1", shape="cds"];
