  l2a_spec_pc_prod -> trans_spec_pc_l2a_l2b;
  l2a_spec_pc_odir -> trans_spec_pc_l2a_l2b;
  l2a_spec_pc_rec -> trans_spec_pc_l2a_l2b;
  l2a_spec_pc_cti -> trans_spec_pc_l2a_l2b;
  l2a_spec_pc_dnb -> trans_spec_pc_l2a_l2b;
  l2a_spec_pc_mbpm -> trans_spec_pc_l2a_l2b;
  l2a_spec_pc_emg -> trans_spec_pc_l2a_l2b;

  trans_spec_pc_l2a_l2b -> l2b_spec_pc_prod;
