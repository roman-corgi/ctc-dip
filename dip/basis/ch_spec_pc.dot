  l4_spec_pc_rspi [label="L4_spec_pc reference star prism image 1..1", shape="cds"];
  l4_spec_pc_lsf [label="L4_spec_pc line spread function 1..1", shape="cds"];

  l1_spec_pc_prod -> trans_spec_pc_l1_l2a;
  l1_spec_pc_man -> trans_spec_pc_l1_l2a;
  l1_spec_pc_odir -> trans_spec_pc_l1_l2a;
  l1_spec_pc_rec -> trans_spec_pc_l1_l2a;
  l1_spec_pc_nln -> trans_spec_pc_l1_l2a;

  trans_spec_pc_l1_l2a -> l2a_spec_pc_prod;
