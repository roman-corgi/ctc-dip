digraph AbstractDesign
{
  graph [splines="ortho", rankdir=LR];

  trans_pol_a_l1_l2a [label="pol_a Transmutation\nL1 to L2a", shape="circle"];
  l2a_pol_a_demux [label="pol_a l2a Demux\nExposure" shape="circle"];
  trans_pol_a_l2a_l2b [label="pol_a Transmutation\nL2a to L2b", shape="circle"];
  l2b_pol_a_mux [label="pol_a l2b Mux\nExposure", shape="circle"];
  trans_pol_a_l2b_l3 [label="pol_a Transmutation\nL2b to L3", shape="circle"];
  trans_pol_a_l3_l4 [label="pol_a Transmutation\nL3 to L4", shape="circle"];
  trans_pol_a_l4_tda [label="pol_a Transmutation\nL4 to TDA", shape="circle"];
        
  l1_pol_a_prod [label="L1_pol_a products 1..b", shape="rectangle"];
  l1_pol_a_man [label="L1_pol_a manifest 1..1", shape="ellipse"];
  l1_pol_a_odir [label="L1_pol_a output path 1..1", shape="ellipse"];
  l1_pol_a_rec [label="L1_pol_a recipe 1..1", shape="cds"];
  l1_pol_a_nln [label="L1_pol_a non-linear & Kgain 1..1", shape="cds"];

  l2a_pol_a_prod [label="L2a_pol_a products 1..b", shape="rectangle"];
  l2a_pol_a_man [label="L2a_pol_a manifest 1..1", shape="ellipse"];
  l2a_pol_a_odir [label="L2a_pol_a output path 1..1", shape="ellipse"];
  l2a_pol_a_rec [label="L2a_pol_a recipe 1..1", shape="cds"];
  l2a_pol_a_cti [label="L2a_pol_a charge xfer inefficiency 1..1", shape="cds"];
  l2a_pol_a_dnb [label="L2a_pol_a detector noise background 1..1", shape="cds"];
  l2a_pol_a_mbpm [label="L2a_pol_a master bad pixel map 1..1", shape="cds"];
  l2a_pol_a_emg [label="L2a_pol_a EM gain 1..1", shape="cds"];
  l2a_pol_a_polff [label="L2a_pol_a polarimetric flat fields 1..1", shape="cds"];
  l2a_pol_a_log [label="L2a log_pol_a 1..1", shape="ellipse"];
  l2a_pol_a_man_demux [label="L2a_pol_a(E) manifest 1..1", shape="ellipse"];
  
  l2b_pol_a_prod [label="L2b_pol_a products 1..1", shape="rectangle"];
  l2b_pol_a_man [label="L2b_pol_a manifest 1..1", shape="ellipse"];
  l2b_pol_a_odir [label="L2b_pol_a output path 1..1", shape="ellipse"];
  l2b_pol_a_rec [label="L2b_pol_a recipe 1..1", shape="cds"];
  l2b_pol_a_excicrf [label="L2b_pol_a EXCAM ICRF location 1..1", shape="cds"];
  l2b_pol_a_excfovps [label="L2b_pol_a EXCAM FOV pixel scale 1..1", shape="cds"];
  l2b_pol_a_cfamfo [label="L2b_pol_a CFAM filter offsets 1..1", shape="cds"];
  l2b_pol_a_man_demux [label="L2b_pol_a(E) manifest 1..1", shape="ellipse"];
  l2b_pol_a_log [label="L2b_pol_a log 1..1", shape="ellipse"];

  l3_pol_a_prod [label="L3_pol_a products 1..1", shape="rectangle"];
  l3_pol_a_odir [label="L3_pol_a output path 1..1", shape="ellipse"];
  l3_pol_a_man [label="L3_pol_a manifest 1..1", shape="ellipse"];
  l3_pol_a_rec [label="L3_pol_a recipe 1..1", shape="cds"];
  l3_pol_a_mueller [label="L3_pol_a mueller matrix 1..1", shape="cds"];
  l3_pol_a_log [label="L3_pol_a log 1..1", shape="ellipse"];

  l4_pol_a_prod [label="L4_pol_a products 1..1", shape="rectangle"];
  l4_pol_a_log [label="L4_pol_a log 1..1", shape="ellipse"];
  l4_pol_a_man [label="L4_pol_a manifest 1..1", shape="ellipse"];
  l4_pol_a_odir [label="L4_pol_a output path 1..1", shape="ellipse"];
  l4_pol_a_rec [label="L4_pol_a recipe 1..1", shape="cds"];
  l4_pol_a_ctcal [label="L4_pol_a core throughput calibrations 1..1", shape="cds"];
  l4_pol_a_pafcal [label="L4_pol_a polarimetric absolute flux calibration 1..1", shape="cds"];

  l1_pol_a_prod -> trans_pol_a_l1_l2a;
  l1_pol_a_man -> trans_pol_a_l1_l2a;
  l1_pol_a_odir -> trans_pol_a_l1_l2a;
  l1_pol_a_rec -> trans_pol_a_l1_l2a;
  l1_pol_a_nln -> trans_pol_a_l1_l2a;

  trans_pol_a_l1_l2a -> l2a_pol_a_prod;
  trans_pol_a_l1_l2a -> l2a_pol_a_man;  
  trans_pol_a_l1_l2a -> l2a_pol_a_log;  

  l2a_pol_a_prod -> trans_pol_a_l2a_l2b;
  l2a_pol_a_odir -> trans_pol_a_l2a_l2b;
  l2a_pol_a_rec -> trans_pol_a_l2a_l2b;
  l2a_pol_a_cti -> trans_pol_a_l2a_l2b;
  l2a_pol_a_dnb -> trans_pol_a_l2a_l2b;
  l2a_pol_a_mbpm -> trans_pol_a_l2a_l2b;
  l2a_pol_a_emg -> trans_pol_a_l2a_l2b;
  l2a_pol_a_polff -> trans_pol_a_l2a_l2b;

  trans_pol_a_l2a_l2b -> l2b_pol_a_prod;
  trans_pol_a_l2a_l2b -> l2b_pol_a_man_demux;
  trans_pol_a_l2a_l2b -> l2b_pol_a_log;

  l2a_pol_a_man -> l2a_pol_a_demux;
  l2a_pol_a_demux -> l2a_pol_a_man_demux;
  l2a_pol_a_man_demux -> trans_pol_a_l2a_l2b;
  
  l2b_pol_a_man_demux -> l2b_pol_a_mux;
  l2b_pol_a_mux -> l2b_pol_a_man;
  
  l2b_pol_a_prod -> trans_pol_a_l2b_l3;
  l2b_pol_a_man -> trans_pol_a_l2b_l3;
  l2b_pol_a_odir -> trans_pol_a_l2b_l3;
  l2b_pol_a_rec -> trans_pol_a_l2b_l3;
  l2b_pol_a_excicrf -> trans_pol_a_l2b_l3;
  l2b_pol_a_excfovps -> trans_pol_a_l2b_l3;
  l2b_pol_a_cfamfo -> trans_pol_a_l2b_l3;
  trans_pol_a_l2b_l3 -> l3_pol_a_prod;
  trans_pol_a_l2b_l3 -> l3_pol_a_man;  
  trans_pol_a_l2b_l3 -> l3_pol_a_log;  

  l3_pol_a_prod -> trans_pol_a_l3_l4;
  l3_pol_a_man -> trans_pol_a_l3_l4;
  l3_pol_a_odir -> trans_pol_a_l3_l4;
  l3_pol_a_rec -> trans_pol_a_l3_l4;
  l3_pol_a_mueller -> trans_pol_a_l3_l4;
  trans_pol_a_l3_l4 -> l4_pol_a_prod;
  trans_pol_a_l3_l4 -> l4_pol_a_log;
  trans_pol_a_l3_l4 -> l4_pol_a_man;

  l4_pol_a_prod -> trans_pol_a_l4_tda;
  l4_pol_a_man -> trans_pol_a_l4_tda;
  l4_pol_a_odir -> trans_pol_a_l4_tda;
  l4_pol_a_rec -> trans_pol_a_l4_tda;
  l4_pol_a_ctcal -> trans_pol_a_l4_tda;
  l4_pol_a_pafcal -> trans_pol_a_l4_tda;
  trans_pol_a_l4_tda -> tda_pol_a_prod;
  trans_pol_a_l4_tda -> tda_pol_a_log;
}
